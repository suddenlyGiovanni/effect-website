---
import "../styles/global.css"

import { Font } from "astro:assets"
import { SEO } from "astro-seo"
import SkipLink from "@/components/SkipLink.astro"
import { OPENGRAPH_IMAGE_HEIGHT, OPENGRAPH_IMAGE_WIDTH } from "@/lib/open-graph"

interface Props {
  readonly title?: string | undefined
  readonly description?: string | undefined
}

const { title = "Effect | Production Grade TypeScript", description } = Astro.props

const getOgImagePath = () => {
  const pathname = Astro.url.pathname
  let slug = pathname.replace(/^\//, "").replace(/\/$/, "")
  if (slug.length === 0) slug = "index"
  return `/og/${slug}.png`
}

const ogImagePath = getOgImagePath()
const ogImageUrl = new URL(ogImagePath, Astro.url.origin)

const pagePathname = Astro.url.pathname.replace(/\/$/, "")
const canonicalUrl = new URL(pagePathname, Astro.site)
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- FONTS -->
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-jetbrains-mono" preload />

    <!-- Remix Icon -->
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.7.0/fonts/remixicon.css"
      rel="stylesheet"
    />

    <!-- Theme: prevent flash of wrong theme, sync data-theme for Starlight CSS -->
    <script is:inline>
      ;(function () {
        var stored = localStorage.getItem("theme")
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
        var isDark =
          stored === "dark" || (stored !== "light" && prefersDark)
        document.documentElement.classList.toggle("dark", isDark)
        document.documentElement.dataset.theme = isDark ? "dark" : "light"
        new MutationObserver(function () {
          var dark = document.documentElement.classList.contains("dark")
          document.documentElement.dataset.theme = dark ? "dark" : "light"
        }).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        })
      })()
    </script>

    <!-- SEO -->
    <SEO
      title={title}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          type: "website",
          url: canonicalUrl,
          title,
          image: ogImageUrl.toString(),
        },
        image: {
          height: OPENGRAPH_IMAGE_HEIGHT,
          width: OPENGRAPH_IMAGE_WIDTH,
        },
        optional: {
          siteName: "Effect",
          ...(description ? { description } : undefined),
        },
      }}
      twitter={{
        card: "summary_large_image",
        title,
        image: ogImageUrl,
        ...(description ? { description } : undefined),
      }}
      extend={{
        link: [{ rel: "icon", type: "image/svg+xml", href: "/favicon.svg" }],
      }}
      {...description ? { description } : undefined}
    />
  </head>
  <body class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-white">
    <SkipLink />
    <slot />
  </body>
</html>
