---
import SocialLink from "@/components/SocialLink.astro"
import SearchTriggerIsland from "@/components/navigation/SearchTriggerIsland"
import ThemeToggle from "@/components/ui/ThemeToggle"

interface Props {
  readonly transparent?: boolean
  readonly showThemeToggle?: boolean
}

const { transparent = false, showThemeToggle = false } = Astro.props
---

<SearchTriggerIsland client:load mode="desktop" transparent={transparent} />

<div
  class={`h-4.5 w-px ${transparent ? "bg-white/50" : "bg-zinc-200 dark:bg-zinc-700"}`}
  aria-hidden="true"
>
</div>

<div class="flex items-center gap-4">
  <SocialLink variant="github" />
  <SocialLink variant="discord" />
</div>

{
  showThemeToggle && (
    <>
      <div
        class={`h-4.5 w-px ${transparent ? "bg-white/50" : "bg-zinc-200 dark:bg-zinc-700"}`}
        aria-hidden="true"
      ></div>
      <ThemeToggle
        client:load
        className={
          transparent
            ? "text-white hover:text-white/80"
            : "text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
        }
      />
    </>
  )
}
