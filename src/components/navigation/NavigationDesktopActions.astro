---
import SocialLink from "@/components/SocialLink.astro"
import SearchTriggerIsland from "@/components/navigation/SearchTriggerIsland"

interface Props {
  readonly transparent?: boolean
}

const { transparent = false } = Astro.props
---

<SearchTriggerIsland client:load mode="desktop" transparent={transparent} />

<div class={`h-4.5 w-px ${transparent ? "bg-white/50" : "bg-zinc-700"}`} aria-hidden="true"></div>

<div class="flex items-center gap-4">
  <SocialLink variant="github" />
  <SocialLink variant="discord" />
</div>
