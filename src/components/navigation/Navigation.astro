---
import NavigationMobileMenu from "@/components/navigation/NavigationMobileMenu.astro"
import NavigationLogo from "@/components/navigation/NavigationLogo.astro"
import NavigationDesktopActions from "@/components/navigation/NavigationDesktopActions.astro"
import NavigationLinks from "@/components/navigation/NavigationLinks.astro"
import SearchDialogIsland from "@/components/navigation/SearchDialogIsland"
import { getNavigationLinks, type NavigationActiveSlug } from "@/lib/navigation"

interface Props {
  readonly transparent?: boolean | undefined
  readonly activeSlug?: NavigationActiveSlug | undefined
  readonly wide?: boolean | undefined
}

const { transparent = false, activeSlug, wide = false } = Astro.props

const mobilePrimaryLinks = getNavigationLinks("mobile", "primary")
const mobileSocialLinks = getNavigationLinks("mobile", "social")
---

<div
  class:list={[
    "fixed top-0 right-0 left-0 z-100 w-full will-change-transform backdrop-blur-sm",
    transparent ? "" : "border-b border-zinc-800 bg-zinc-950/85",
  ]}
>
  <div class="w-full">
    <header class:list={["relative mx-auto w-full px-4", wide ? "max-w-352" : "max-w-295"]}>
      <nav class="flex h-16 items-center">
        <NavigationLogo />

        <div class="ml-8 hidden items-center gap-6 md:flex">
          <NavigationLinks transparent={transparent} activeSlug={activeSlug} />
        </div>

        <NavigationMobileMenu
          transparent={transparent}
          primaryLinks={mobilePrimaryLinks}
          socialLinks={mobileSocialLinks}
          activeSlug={activeSlug}
        />

        <div class="ml-auto hidden items-center gap-4.5 md:flex">
          <NavigationDesktopActions transparent={transparent} />
        </div>
      </nav>
    </header>
  </div>
</div>

<SearchDialogIsland client:load />
