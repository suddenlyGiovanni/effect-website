---
import type { NavigationLink } from "@/lib/navigation"
import { cn } from "@/lib/utils"

interface Props {
  readonly link: NavigationLink
  readonly class: string
  readonly ariaLabel?: string
  readonly active?: boolean
  readonly activeClass?: string
}

const { link, class: className, ariaLabel, active = false, activeClass } = Astro.props
const anchorClass = cn(className, active && activeClass)
---

{
  link.kind === "external" ? (
    <a
      href={link.href}
      target={link.target}
      rel={link.rel}
      class={anchorClass}
      aria-label={ariaLabel}
    >
      <slot>{link.label}</slot>
    </a>
  ) : (
    <a
      href={link.href}
      class={anchorClass}
      aria-label={ariaLabel}
      aria-current={active ? "page" : undefined}
    >
      <slot>{link.label}</slot>
    </a>
  )
}
