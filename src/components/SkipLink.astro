---
import { PAGE_TITLE_ID } from "@/lib/constants/skip-link"
import { cn } from "@/lib/utils"
import Link from "./Link.astro"
---

<Link
  href={`#${PAGE_TITLE_ID}`}
  class={cn(
    "fixed top-3 inset-s-3",
    "[clip:rect(0,0,0,0)] focus:[clip:unset]",
    "focus:fixed focus:block",
    "focus:z-10000 focus:px-4 focus:py-2 focus:no-underline",
    "bg-accent text-white"
  )}
>
  Skip to content
</Link>
