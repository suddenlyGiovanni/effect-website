---
interface Props {
  readonly class?: string | undefined
}

const { class: className } = Astro.props
---

<div 
  aria-hidden="true" 
  class:list={[
    "dithered-background-overlay pointer-events-none fixed inset-0 z-0 opacity-[0.03]",
    className
  ]} 
/>

<style>
  .dithered-background-overlay {
    background-image: url("data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%274%27 height=%274%27%3E%3Crect x=%270%27 y=%270%27 width=%271%27 height=%271%27 fill=%27white%27/%3E%3Crect x=%272%27 y=%272%27 width=%271%27 height=%271%27 fill=%27white%27/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 4px 4px;
  }
</style>
