---
interface Props {
  readonly class?: string | undefined
}

const { class: className } = Astro.props
---

<div 
  aria-hidden="true" 
  class:list={[
    "pointer-events-none absolute inset-0 z-60 hidden lg:block",
    className
  ]}
>
  <div class="relative mx-auto h-full w-full max-w-295">
    <div class="absolute inset-y-0 left-0 w-px bg-zinc-800"></div>
    <div class="absolute inset-y-0 right-0 w-px bg-zinc-800"></div>
  </div>
</div>

<div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0 hidden lg:block">
  <div class="relative mx-auto h-full w-full max-w-295">
    <div class="landing-rails-center absolute inset-y-0 left-1/2 w-px -translate-x-1/2"></div>
  </div>
</div>

<style>
  .landing-rails-center {
    background-image: repeating-linear-gradient(
      to bottom,
      rgb(39 39 42) 0,
      rgb(39 39 42) 2px,
      transparent 2px,
      transparent 4px
    );
  }
</style>
