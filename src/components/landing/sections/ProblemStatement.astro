---
import { Activity, ArrowDown, Check, Clock3, FileCheck2, GitBranch, Network, ShieldCheck } from "@lucide/astro"
import ComplexityChart from "@/components/landing/blocks/ComplexityChart.astro"

type ProblemFeatureIcon =
  | "typed-errors"
  | "dependency-injection"
  | "structured-concurrency"
  | "scheduling"
  | "built-in-tracing"
  | "unified-schema"

type ProblemFeature = {
  readonly problem: string
  readonly icon: ProblemFeatureIcon
  readonly title: string
  readonly description: string
  readonly items: ReadonlyArray<string>
}

const PROBLEM_FEATURES: ReadonlyArray<ProblemFeature> = [
  {
    problem: "Try-catch blocks everywhere but you still do not know how things can fail.",
    icon: "typed-errors",
    title: "Typed Errors",
    description: "Errors in the type system. The compiler tells you what can fail.",
    items: [
      "Typed errors in function signatures",
      "Short-circuit or collect failures",
      "Automatic retry with backoff",
    ],
  },
  {
    problem: "Another decorator. Another magic string. Another runtime error.",
    icon: "dependency-injection",
    title: "Dependency Injection",
    description: "Services as types, provided at the edge. No decorators, no magic.",
    items: [
      "Type-safe service definitions",
      "Automatic dependency resolution",
      "Easy mocking for tests",
    ],
  },
  {
    problem: "That Promise.all call? One failure and everything crashes.",
    icon: "structured-concurrency",
    title: "Structured Concurrency",
    description: "Fibers with cancellation, cleanup, and resource safety.",
    items: [
      "Structured concurrency with fibers",
      "Parallel execution with limits",
      "Automatic resource cleanup",
    ],
  },
  {
    problem: "Network failed? Try again later. But when, and how many times?",
    icon: "scheduling",
    title: "Scheduling",
    description: "Declarative retry, repeat, and timeout policies.",
    items: ["Cron-like schedules", "Exponential backoff", "Jittered retries"],
  },
  {
    problem: "No observability. Production is on fire and you do not know why.",
    icon: "built-in-tracing",
    title: "Built-in Tracing",
    description: "OpenTelemetry out of the box. Full context with low setup.",
    items: ["Built-in OpenTelemetry tracing", "Structured logging", "Metrics collection"],
  },
  {
    problem: "Validation logic is duplicated across every layer of your application.",
    icon: "unified-schema",
    title: "Unified Schema",
    description: "One schema for validation, encoding, and documentation.",
    items: [
      "Runtime validation from types",
      "Automatic JSON serialization",
      "API contract generation",
    ],
  },
]
---

<section id="problem" class="relative w-full">
  <div class="relative mx-auto w-full max-w-295 px-4">
    <div class="mb-8 md:mb-16 grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-8">
      <div>
        <p class="mb-3 font-mono text-sm font-medium uppercase tracking-wider text-zinc-400">
          // What Effect Solves
        </p>
        <h2 class="max-w-md text-3xl font-semibold leading-tight text-white md:text-4xl">
          Built-in solutions for the hard problems
        </h2>
      </div>

      <div class="flex flex-col justify-center">
        <ComplexityChart />
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {PROBLEM_FEATURES.map((feature) => (
        <article class="flex flex-col border border-zinc-800 bg-zinc-950 p-5">
          <p class="text-base font-medium leading-snug text-zinc-400">{feature.problem}</p>

          <div class="my-4 flex items-center gap-2">
            <div class="h-px flex-1 bg-zinc-800"></div>
            <ArrowDown class="h-4 w-4 text-white" aria-hidden="true" />
            <div class="h-px flex-1 bg-zinc-800"></div>
          </div>

          <h3 class="flex items-center gap-2 font-mono text-base font-medium uppercase text-white">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center bg-zinc-800">
              {feature.icon === "typed-errors" ? (
                <ShieldCheck class="h-4 w-4 text-zinc-200" aria-hidden="true" />
              ) : feature.icon === "dependency-injection" ? (
                <Network class="h-4 w-4 text-zinc-200" aria-hidden="true" />
              ) : feature.icon === "structured-concurrency" ? (
                <GitBranch class="h-4 w-4 text-zinc-200" aria-hidden="true" />
              ) : feature.icon === "scheduling" ? (
                <Clock3 class="h-4 w-4 text-zinc-200" aria-hidden="true" />
              ) : feature.icon === "built-in-tracing" ? (
                <Activity class="h-4 w-4 text-zinc-200" aria-hidden="true" />
              ) : (
                <FileCheck2 class="h-4 w-4 text-zinc-200" aria-hidden="true" />
              )}
            </span>
            {feature.title}
          </h3>

          <ul class="mt-3 m-0 flex list-none flex-col gap-1.5 p-0">
            {feature.items.map((item) => (
              <li class="flex items-start gap-2">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center">
                  <Check class="h-4 w-4 text-emerald-500" aria-hidden="true" />
                </span>
                <span class="text-sm text-zinc-400">{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
