---
import { ArrowRight } from "@lucide/astro"
import DiscordLogo from "@/assets/logos/discord/Discord.svg"
import EffectImport from "../blocks/EffectImport.astro"
import InstallCommand from "../blocks/InstallCommand.astro"
---

<section id="call-to-action" class="relative w-full">
  <!-- Grid  -->
  <div
    class="call-to-action-grid absolute inset-0 pointer-events-none"
    aria-hidden="true"
  />

  <!-- Fade Grid Top & Bottom  -->
  <div
    class="call-to-action-fade absolute inset-0 pointer-events-none"
    aria-hidden="true"
  />

  <!-- Texture Overlay -->
  <div
    class="call-to-action-noise absolute inset-0 pointer-events-none opacity-[0.015]"
    aria-hidden="true"
  />


  <div class="relative mx-auto w-full max-w-295 px-4">
    <div class="flex flex-col items-center text-center">
      <EffectImport />

      <h2 class="leading-tighter max-w-3xl text-4xl md:text-5xl font-bold text-white">
        Stop installing a new package for every problem
      </h2>

      {/* Install command */}
      <div class="mt-8 w-full max-w-139">
        <InstallCommand />
      </div>

      {/* CTA Buttons */}
      <div class="mt-6 flex flex-row items-center justify-center gap-3">
        <a 
          class="inline-flex justify-center items-center gap-2 px-6 py-4 bg-zinc-900 hover:bg-zinc-800 text-white text-base font-medium border border-zinc-700 hover:border-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white disabled:pointer-events-none disabled:opacity-50 rounded-md no-underline group"
          href="/docs/"
        >
          <ArrowRight class="size-4 transition-transform group-hover:translate-x-0.5" />
          <span>Get Started</span>
        </a>
        <a 
          class="inline-flex justify-center items-center gap-4 px-4 md:px-6 py-4 bg-zinc-900 hover:bg-zinc-800 text-white text-base font-medium border border-zinc-700 hover:border-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white disabled:pointer-events-none disabled:opacity-50 rounded-md no-underline group"
          href="https://discord.gg/effect-ts"
          target="_blank"
          rel="noopener noreferrer"
        >
          <DiscordLogo class="size-4" fill="currentColor" />
          <span>Join Discord</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .call-to-action-grid {
    --call-to-action-grid-image: linear-gradient(
        to right,
        rgb(24 24 27 / 0.8) 1px,
        transparent 1px
      ),
      linear-gradient(to bottom, rgb(24 24 27 / 0.8) 1px, transparent 1px);
    --call-to-action-grid-size: 196.6px 180px;
    --call-to-action-grid-position: calc(50% + 97px) 0;

    background-image: var(--call-to-action-grid-image);
    background-size: var(--call-to-action-grid-size);
    background-position: var(--call-to-action-grid-position);
  }

  .call-to-action-fade {
    background: linear-gradient(to bottom, #09090b 0%, transparent 15%, transparent 80%, #09090b 100%);
  }

  .call-to-action-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }
</style>
