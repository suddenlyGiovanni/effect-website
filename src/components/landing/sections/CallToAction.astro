---
import { ArrowRight } from "@lucide/astro"
import DiscordLogo from "@/assets/logos/discord/Discord.svg"
import GridBackground from "@/components/GridBackground.astro"
import HeroCommandPanel from "@/components/landing/blocks/HeroCommandPanel.astro"
---

<section class="relative w-full overflow-hidden py-36 md:py-24">
  <GridBackground />

  <div class="relative mx-auto w-full max-w-295 px-4">
    <div class="flex flex-col items-center text-center">
      <p class="mb-3 font-mono text-base text-zinc-500">
        <span>import {"{ "}</span>
        <span class="text-white">Effect</span>
        <span>{" }"} from "effect"</span>
      </p>

      <h2 class="leading-tighter max-w-3xl text-4xl font-bold text-white">
        Stop installing a new package for every problem
      </h2>

      <div class="mx-auto mt-8 max-w-xl w-full">
        <HeroCommandPanel />
      </div>

      <div class="mt-6 flex flex-row items-center justify-center gap-3">
        <a
          href="/docs/"
          class="group inline-flex w-44 items-center justify-center gap-2 rounded-md border border-zinc-700 bg-zinc-900/50 px-6 py-3 text-base font-medium text-white no-underline transition-all hover:border-zinc-500 hover:bg-zinc-800 hover:no-underline"
        >
          <ArrowRight
            class="size-4 transition-transform group-hover:translate-x-0.5"
            aria-hidden="true"
          />
          Get started
        </a>
        <a
          href="https://discord.gg/effect-ts"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-44 items-center justify-center gap-2 rounded-md border border-zinc-700 bg-zinc-900/50 px-6 py-3 text-base font-medium text-white no-underline transition-all hover:border-zinc-500 hover:bg-zinc-800 hover:no-underline"
        >
          <DiscordLogo class="size-4" fill="currentColor" />
          Join Discord
        </a>
      </div>
    </div>
  </div>
</section>
