---
import VisualEffects from "@/components/landing/examples/VisualEffects" 
---

<section id="examples" class="relative w-full py-24 md:pt-40 md:pb-24">
  <div class="mx-auto w-full max-w-295">
    <div class="mx-auto w-full max-w-295 px-4 mb-12">
      <p class="mb-3 font-mono text-sm font-medium uppercase tracking-wider text-zinc-400">
        // Interactive Examples
      </p>
      <h2 class="text-3xl font-semibold text-white md:text-4xl">
        See Effect in action
      </h2>
    </div>
    <div class="max-w-295 mx-auto">
      <VisualEffects client:load />
      <noscript>
        <div class="mt-6 border border-zinc-800 bg-zinc-950/70 p-4 text-sm text-zinc-400">
          Interactive examples require JavaScript.
        </div>
      </noscript>
    </div>
  </div>
</section>
