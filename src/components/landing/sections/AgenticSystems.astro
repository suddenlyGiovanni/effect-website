---
import { Image } from "astro:assets"
import { ArrowRight, ArrowUpRight, GitFork, History, Layers, VectorSquare } from "@lucide/astro"
import EffectLogo from "@/assets/logos/effect/combination-mark/svg/effect-logo-white.svg"
import MasterclassLogo from "@/assets/logos/masterclass/Masterclass.svg"
import _14aiLogo from "@/assets/logos/14ai/14ai.svg"
import GitHubIcon from "@/assets/logos/github/GitHub.svg"
---

<section id="agentic-systems" class="relative w-full">
  <div class="relative mx-auto w-full max-w-295">
    <div class="mb-8 lg:mb-12 px-4">
      <p class="mb-3 font-mono text-sm font-medium uppercase tracking-wider text-muted-foreground">
        // Effect for AI
      </p>
      <h2 class="text-3xl leading-tight font-semibold text-white md:text-4xl">
        Build Agentic Systems
      </h2>
      <p class="max-w-2xl mt-4 text-xl text-muted-foreground">
        Reliable orchestration, parallel execution, state management, and fault recovery, all with
        type safety and semantic observability.
      </p>

      <div class="flex gap-3 mt-4 lg:mt-8">
        <a
          href="/docs/ai/introduction/"
          class="inline-flex justify-center items-center gap-2 px-5 py-2.5 bg-zinc-900/50 hover:bg-zinc-800 text-white text-sm font-medium border border-zinc-700 hover:border-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white disabled:pointer-events-none disabled:opacity-50 rounded-md no-underline group"
        >
          <span>Read the docs</span>
          <ArrowRight class="size-4 transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href="https://github.com/Effect-TS/effect-smol/tree/main/packages/effect/src/unstable/ai/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex justify-center items-center gap-2 px-5 py-2.5 bg-zinc-900/50 hover:bg-zinc-800 text-white text-sm font-medium border border-zinc-700 hover:border-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white disabled:pointer-events-none disabled:opacity-50 rounded-md no-underline group"
        >
          <GitHubIcon class="size-4" fill="currentColor" />
          <span>GitHub</span>
        </a>
      </div>
    </div>

    <div class="mb-8 lg:mb-12 px-4 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-0">
      <div class="flex flex-col pr-8 pl-4 lg:pl-0 lg:border-r lg:border-dashed lg:border-zinc-700">
        <VectorSquare class="size-5 mb-2 text-lg text-zinc-300" />
        <h3 class="text-base">Type-safe data flows</h3>
        <p class="mt-1 text-sm text-muted-foreground leading-relaxed">
          Connect AI outputs to frontend UI without schema mismatches.
        </p>
      </div>

      <div class="flex flex-col pr-8 pl-4 lg:border-r lg:border-transparent">
        <GitFork class="size-5 mb-2 text-lg text-zinc-300" />
        <h3 class="text-base">Deterministic concurrency</h3>
        <p class="mt-1 text-sm text-muted-foreground leading-relaxed">
          Runs and scales agent pipelines safely.
        </p>
      </div>

      <div class="flex flex-col pr-8 pl-4 lg:border-r lg:border-dashed lg:border-zinc-700">
        <History class="size-5 mb-2 text-lg text-zinc-300" />
        <h3 class="text-base">Durable agent execution</h3>
        <p class="mt-1 text-sm text-muted-foreground leading-relaxed">
          Reliable communication between agent nodes with&nbsp;
          <a href="/docs/cluster/introduction/" class="text-foreground underline-offset-2"
            >Effect Cluster</a
          >.
        </p>
      </div>

      <div class="flex flex-col pl-4">
        <Layers class="size-5 mb-2 text-lg text-zinc-300" />
        <h3 class="text-base">Composable infrastructure</h3>
        <p class="mt-1 text-sm text-muted-foreground leading-relaxed">
          Easily integrates with LLMs, APIs, vector databases, and more.
        </p>
      </div>
    </div>

    <!-- Features -->
    <div class="px-4 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div
        class="group relative flex flex-col bg-zinc-950 hover:bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-lg overflow-hidden transition-colors cursor-pointer"
      >
        <!-- Decorative Accent Line -->
        <div
          class="pointer-events-none absolute top-0 right-0 left-0 h-0.5 bg-violet-500"
          aria-hidden="true"
        >
        </div>
        <!-- Decorative Gradient Background -->
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_100%_at_100%_100%,rgba(139,92,246,0.4)_0%,rgba(168,85,247,0.2)_40%,transparent_70%)] group-hover:opacity-100 transition-opacity"
          aria-hidden="true"
        >
        </div>
        <!-- Content -->
        <div class="relative flex flex-col gap-4 p-8">
          <!-- Title -->
          <h4>
            <a
              class="after:absolute after:content-[''] after:-inset-px after:z-1 no-underline"
              href="https://youtu.be/Cj2pVPqdOVs"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span
                class="text-sm text-muted-foreground font-mono font-medium uppercase group-hover:text-white transition-colors"
              >
                // Voice AI Orchestration Layer
              </span>
            </a>
          </h4>
          <!-- Dashed Divider -->
          <div
            class="w-full h-px bg-[repeating-linear-gradient(to_right,rgb(39_39_42)_0px,rgb(39_39_42)_2px,transparent_2px,transparent_4px)]"
            aria-hidden="true"
          >
          </div>
          <!-- Logos -->
          <div class="flex justify-between items-center">
            <div class="flex items-center gap-5">
              <Image class="h-6 w-auto" src={EffectLogo} alt="Effect Logo" />
              <span class="text-zinc-600">&vert;</span>
              <Image class="h-4 w-auto" src={MasterclassLogo} alt="Masterclass Logo" />
            </div>
            <ArrowUpRight class="size-4" />
          </div>
        </div>
      </div>

      <div
        class="group relative flex flex-col bg-zinc-950 hover:bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-lg overflow-hidden transition-colors cursor-pointer"
      >
        <!-- Decorative Accent Line -->
        <div
          class="pointer-events-none absolute top-0 right-0 left-0 h-0.5 bg-emerald-400"
          aria-hidden="true"
        >
        </div>
        <!-- Decorative Gradient Background -->
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_100%_at_100%_100%,rgba(16,185,129,0.35)_0%,rgba(52,211,153,0.2)_40%,transparent_70%)] group-hover:opacity-100 transition-opacity"
          aria-hidden="true"
        >
        </div>
        <!-- Content -->
        <div class="relative flex flex-col gap-4 p-8">
          <!-- Title -->
          <h4>
            <a
              class="after:absolute after:content-[''] after:-inset-px after:z-1 no-underline"
              href="https://youtu.be/gGFPhFrGCng"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span
                class="text-sm text-muted-foreground font-mono font-medium uppercase group-hover:text-white transition-colors"
              >
                // AI for Customer Support
              </span>
            </a>
          </h4>
          <!-- Dashed Divider -->
          <div
            class="w-full h-px bg-[repeating-linear-gradient(to_right,rgb(39_39_42)_0px,rgb(39_39_42)_2px,transparent_2px,transparent_4px)]"
            aria-hidden="true"
          >
          </div>
          <!-- Logos -->
          <div class="flex justify-between items-center">
            <div class="flex items-center gap-5">
              <Image class="h-6 w-auto" src={EffectLogo} alt="Effect Logo" />
              <span class="text-zinc-600">&vert;</span>
              <Image class="h-6 w-auto" src={_14aiLogo} alt="14.ai Logo" />
            </div>
            <ArrowUpRight class="size-4" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
