---
import { ArrowRight, PlayCircle } from "@lucide/astro"

import AgentCommand from "../blocks/AgentCommand.astro"
import InstallCommand from "../blocks/InstallCommand.astro"

import heroNoise from "@/assets/images/hero-noise-texture.png?url"
---

<section class="hero-section relative w-full bg-cover bg-center-top" style={`background-image: url("${heroNoise}");`}>
  <!-- Grid background -->
  <div aria-hidden="true" class="hero-grid pointer-events-none absolute inset-0"></div>
  <!-- Fade -->
  <div aria-hidden="true" class="hero-fade pointer-events-none absolute inset-0"></div>
  <!-- Glow -->
  <div aria-hidden="true" class="hero-glow pointer-events-none absolute inset-x-0 top-0 h-[600px]"></div>
<div class="relative mx-auto w-full max-w-295 px-4 py-20 md:px-24">
    <div class="max-w-4xl text-left md:mx-auto md:text-center">
      <!-- Eyebrow -->
      <a
        href="/blog/releases/effect/40-beta"
        class="group mb-4 inline-flex items-center gap-2 font-mono text-xs tracking-wider text-zinc-300 uppercase transition-colors hover:text-white md:text-sm"
      >
        <span class="text-zinc-500 group-hover:text-zinc-400">//</span>
        <span>Effect 4.0 — Now in Beta</span>
        <ArrowRight class="text-zinc-500 transition-transform group-hover:translate-x-0.5 group-hover:text-zinc-300" size={16} aria-hidden="true" />
      </a>

      <h1 class="text-4xl font-bold text-white leading-tighter md:text-[3.4rem]">
        Reliable TypeScript for the AI era
      </h1>

      <p class="mt-6 text-lg text-zinc-400 max-w-3xl leading-snug md:mx-auto">
        Build production-ready systems with the structure, safety, and observability developers need — and AI agents can work with.
      </p>

      <div class="mt-8 grid gap-4 md:mx-auto md:max-w-4xl md:grid-cols-2">
        <InstallCommand />
        <AgentCommand />
      </div>
    </div>
  </div>

  <!-- Video -->
  <div class="relative z-10 mx-auto mt-12 w-full max-w-295 px-4 pb-20 md:pb-24">
    <div class="mx-auto max-w-5xl aspect-video rounded-lg border border-zinc-800 bg-zinc-900 flex items-center justify-center">
      <div class="flex flex-col items-center gap-3 text-zinc-400">
        <PlayCircle class="h-12 w-12" aria-hidden="true" />
        <span class="text-sm font-medium">Video coming soon</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    --hero-grid-gradient-x: linear-gradient(to right, rgba(24, 24, 27, 0.8) 1px, transparent 1px);
    --hero-grid-gradient-y: linear-gradient(to bottom, rgba(24, 24, 27, 0.8) 1px, transparent 1px);
    --hero-grid-size: 196.6px 194px;
    --hero-grid-position: calc(50% + 97px) 0;
    --hero-glow-gradient:
      radial-gradient(ellipse 50% 80% at 70% -20%, rgba(255, 255, 255, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse 30% 50% at 80% 0%, rgba(255, 255, 255, 0.08) 0%, transparent 40%);
  }

  .hero-grid {
    background-image: var(--hero-grid-gradient-x), var(--hero-grid-gradient-y);
    background-size: var(--hero-grid-size);
    background-position: var(--hero-grid-position);
  }

  .hero-fade {
    background: linear-gradient(to bottom, #09090b 0%, transparent 20%, transparent 60%, #09090b 100%);
  }

  @keyframes hero-glow-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .hero-glow {
    background: var(--hero-glow-gradient);
    animation: hero-glow-pulse 4s ease-in-out infinite;
    will-change: opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-glow {
      animation: none;
    }
  }
</style>
