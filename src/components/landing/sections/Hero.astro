---
import { PAGE_TITLE_ID } from "@/lib/constants/skip-link"
import EffectImport from "../blocks/EffectImport.astro"
import InstallCommand from "../blocks/InstallCommand.astro"
---

<section class="hero-section relative w-full overflow-hidden">
  <!-- Stripe-like grid background - full width, centered -->
  <div
    aria-hidden="true"
    class="hero-grid pointer-events-none absolute inset-0"
  />
  <!-- Fade out grid at top and bottom -->
  <div
    aria-hidden="true"
    class="hero-fade pointer-events-none absolute inset-0"
  />

  <!-- Subtle glow - Stripe-style ambient light with pulse animation -->
  <div
    aria-hidden="true"
    class="hero-glow pointer-events-none absolute inset-x-0 top-0 h-144"
  />

  <div class="relative mx-auto w-full max-w-295 px-4 pt-20 md:pt-24">
    <div class="mx-auto max-w-4xl text-center">
      <EffectImport />

      <h1 id={PAGE_TITLE_ID} class="text-4xl font-bold leading-tighter text-white md:text-6xl">
        The missing standard library for TypeScript applications
      </h1>

      <p class="mx-auto mt-6 max-w-3xl text-[1.25rem] leading-snug text-zinc-400">
        Effect is an open-source ecosystem for building software that is scalable,
        reliable, and maintainable from the start.
      </p>

      <div class="mx-auto mt-8 max-w-139">
        <InstallCommand />
      </div>
    </div>
  </div>

  <div class="relative z-10 mx-auto mt-12 w-full max-w-295 px-4">
    <div class="mx-auto flex aspect-video max-w-5xl items-center justify-center rounded-lg border border-zinc-800 bg-zinc-900/80 backdrop-blur-sm">
      <div class="flex flex-col items-center gap-3 text-zinc-500">
        <svg viewBox="0 0 24 24" class="h-16 w-16" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM12 20C16.4183 20 20 16.4183 20 12C20 7.58172 16.4183 4 12 4C7.58172 4 4 7.58172 4 12C4 16.4183 7.58172 20 12 20ZM10.6219 8.41459L15.5008 11.6672C15.6846 11.7897 15.7343 12.0381 15.6117 12.2219C15.5824 12.2658 15.5447 12.3035 15.5008 12.3328L10.6219 15.5854C10.4381 15.708 10.1897 15.6583 10.0672 15.4745C10.0234 15.4088 10 15.3316 10 15.2526V8.74741C10 8.52649 10.1791 8.34741 10.4 8.34741C10.479 8.34741 10.5562 8.37078 10.6219 8.41459Z" />
        </svg>
        <p class="text-sm font-medium">Video coming soon</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    --hero-grid-gradient-x: linear-gradient(to right, rgb(39 39 42 / 0.45) 1px, transparent 1px);
    --hero-grid-gradient-y: linear-gradient(to bottom, rgb(39 39 42 / 0.45) 1px, transparent 1px);
    --hero-grid-size: 196px 194px;
    --hero-grid-position: calc(50% + 98px) 0;
    --hero-fade-gradient: linear-gradient(
      to bottom,
      rgb(9 9 11) 0%,
      transparent 20%,
      transparent 65%,
      rgb(9 9 11) 100%
    );
    --hero-glow-gradient: radial-gradient(
        ellipse 50% 80% at 70% -20%,
        rgb(255 255 255 / 0.08) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse 32% 56% at 80% 0%,
        rgb(255 255 255 / 0.05) 0%,
        transparent 40%
      );
  }

  .hero-grid {
    background-image: var(--hero-grid-gradient-x), var(--hero-grid-gradient-y);
    background-size: var(--hero-grid-size);
    background-position: var(--hero-grid-position);
  }

  .hero-fade {
    background: var(--hero-fade-gradient);
  }

  @keyframes hero-glow-pulse {
    0%,
    100% {
      opacity: 1;
    }

    50% {
      opacity: 0.6;
    }
  }

  .hero-glow {
    background: var(--hero-glow-gradient);
    animation: hero-glow-pulse 4s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-glow {
      animation: none;
    }
  }
</style>
