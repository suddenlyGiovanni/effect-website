---
import type { ImageMetadata } from "astro"
import type { SvgComponent } from "astro/types"
import { Copy, Check } from "@lucide/astro"

import {
  DEFAULT_PACKAGE_MANAGER,
  getInstallCommand,
  PACKAGE_MANAGERS,
  type PackageManager,
} from "@/lib/install-command"
import BunLogo from "@/assets/logos/bun/Bun.svg"
import DenoLogo from "@/assets/logos/deno/Deno.svg"
import NpmFullLogo from "@/assets/logos/npm/NpmFull.svg"
import PnpmLogo from "@/assets/logos/pnpm/Pnpm.svg"
import YarnLogo from "@/assets/logos/yarn/Yarn.svg"

const PM_ICONS: Record<
  PackageManager,
  { readonly icon: ImageMetadata & SvgComponent; readonly className: string }
> = {
  bun: { icon: BunLogo, className: "h-3.5 w-auto" },
  deno: { icon: DenoLogo, className: "h-3.5 w-auto" },
  npm: { icon: NpmFullLogo, className: "h-4 w-auto fill-white" },
  pnpm: { icon: PnpmLogo, className: "h-3.5 w-auto" },
  yarn: { icon: YarnLogo, className: "h-3.5 w-auto" },
}
---

<effect-hero-command
  class="relative block rounded-md bg-[#101012] p-1 ring-1 ring-inset ring-zinc-700"
>

  <div
    data-role="copy"
    role="button"
    tabindex="0"
    class="flex min-h-11 w-full cursor-pointer items-center gap-3 px-4 py-1 text-left font-mono text-sm text-zinc-300 transition-colors hover:bg-[#17171A]"
    aria-label="Copy install command"
  >
    <div data-role="pm-dropdown" class="relative shrink-0">
      <button
        type="button"
        data-role="pm-chip"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-label="Package manager: bun"
        class="flex items-center gap-1.5 rounded-sm border-r border-zinc-800 py-0.5 pr-3 pl-1 text-xs text-zinc-300 transition-colors hover:text-white cursor-pointer"
      >
        <span data-role="pm-icon-active" aria-hidden="true">
          {
            PACKAGE_MANAGERS.map((pm) => {
              const { icon: Icon, className: iconClass } = PM_ICONS[pm]
              return (
                <Icon
                  data-pm-icon={pm}
                  class:list={[iconClass, pm === DEFAULT_PACKAGE_MANAGER ? "" : "hidden"]}
                />
              )
            })
          }
        </span>
        <span data-role="pm-label">{DEFAULT_PACKAGE_MANAGER}</span>
        <svg
          data-role="pm-chevron"
          class="size-4 text-zinc-500 transition-transform"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </button>

      <ul
        data-role="pm-popover"
        role="listbox"
        hidden
        class="absolute top-full left-0 z-20 mt-2 w-36 overflow-hidden rounded-md border border-zinc-800 bg-zinc-900 shadow-xl"
      >
        {
          PACKAGE_MANAGERS.map((pm) => {
            const { icon: Icon, className: iconClass } = PM_ICONS[pm]
            const isDefault = pm === DEFAULT_PACKAGE_MANAGER
            return (
              <li>
                <button
                  type="button"
                  role="option"
                  data-role="pm-option"
                  data-pm={pm}
                  aria-selected={isDefault ? "true" : "false"}
                  class="flex w-full items-center gap-2.5 px-3 py-2 text-left text-sm transition-colors hover:bg-zinc-800 cursor-pointer"
                  class:list={[isDefault ? "text-white" : "text-zinc-400"]}
                >
                  <Icon class={iconClass} />
                  <span class="flex-1">{pm}</span>
                  <Check
                    data-role="pm-check"
                    size={16}
                    class:list={["shrink-0 text-zinc-500", isDefault ? "" : "hidden"]}
                    aria-hidden="true"
                  />
                </button>
              </li>
            )
          })
        }
      </ul>
    </div>

    <span data-role="command-text" class="flex-1 truncate">{getInstallCommand(DEFAULT_PACKAGE_MANAGER)}</span>

    <Copy data-role="copy-icon-idle" class="shrink-0 text-zinc-400" size={16} aria-hidden="true" />
    <Check data-role="copy-icon-copied" class="hidden shrink-0 text-zinc-200" size={16} aria-hidden="true" />
  </div>

  <p role="status" aria-live="polite" data-role="status" class="sr-only"></p>
</effect-hero-command>

<script>
  import {
    DEFAULT_PACKAGE_MANAGER,
    getInstallCommand,
    PACKAGE_MANAGERS,
    type PackageManager,
  } from "@/lib/install-command"

  const COPY_RESET_TIMEOUT_MS = 1500
  const PACKAGE_MANAGER_SET: ReadonlySet<string> = new Set(PACKAGE_MANAGERS)

  const isPackageManager = (value: string): value is PackageManager => {
    return PACKAGE_MANAGER_SET.has(value)
  }

  class EffectHeroCommandElement extends HTMLElement {
    #activePM: PackageManager = DEFAULT_PACKAGE_MANAGER
    #pmOpen = false

    #pmDropdown: HTMLElement | null = null
    #pmChip: HTMLButtonElement | null = null
    #pmChevron: Element | null = null
    #pmPopover: HTMLElement | null = null
    #pmIconContainer: HTMLElement | null = null
    #pmLabel: HTMLElement | null = null
    #pmOptions = new Map<PackageManager, HTMLButtonElement>()
    #copyElement: HTMLElement | null = null
    #commandText: HTMLElement | null = null
    #statusElement: HTMLElement | null = null
    #copyIdleIcon: Element | null = null
    #copySuccessIcon: Element | null = null
    #copyResetTimeout: ReturnType<typeof setTimeout> | undefined = undefined

    #closePopover = () => {
      if (!this.#pmOpen) return
      this.#pmOpen = false
      if (this.#pmChip) this.#pmChip.setAttribute("aria-expanded", "false")
      if (this.#pmPopover) this.#pmPopover.hidden = true
      if (this.#pmChevron) this.#pmChevron.classList.remove("rotate-180")
    }

    #onOutsideClick = (event: MouseEvent) => {
      if (!this.#pmOpen) return
      const target = event.target as Node
      if (this.#pmDropdown && !this.#pmDropdown.contains(target)) {
        this.#closePopover()
      }
    }

    #onEscape = (event: KeyboardEvent) => {
      if (event.key === "Escape") {
        this.#closePopover()
      }
    }

    connectedCallback() {
      this.#pmDropdown = this.querySelector("[data-role='pm-dropdown']")
      this.#pmChip = this.querySelector("[data-role='pm-chip']")
      this.#pmChevron = this.querySelector("[data-role='pm-chevron']")
      this.#pmPopover = this.querySelector("[data-role='pm-popover']")
      this.#pmIconContainer = this.querySelector("[data-role='pm-icon-active']")
      this.#pmLabel = this.querySelector("[data-role='pm-label']")

      const pmOptionElements = this.querySelectorAll("[data-role='pm-option']")
      pmOptionElements.forEach((el) => {
        if (!(el instanceof HTMLButtonElement)) return
        const pm = el.dataset.pm
        if (pm === undefined || !isPackageManager(pm)) return
        this.#pmOptions.set(pm, el)
        el.addEventListener("click", this.#onPMSelect)
      })

      if (this.#pmChip) {
        this.#pmChip.addEventListener("click", this.#onPMChipClick)
      }

      document.addEventListener("mousedown", this.#onOutsideClick)
      document.addEventListener("keydown", this.#onEscape)

      const copyElement = this.querySelector("[data-role='copy']")
      const commandText = this.querySelector("[data-role='command-text']")
      const statusElement = this.querySelector("[data-role='status']")
      const copyIdleIcon = this.querySelector("[data-role='copy-icon-idle']")
      const copySuccessIcon = this.querySelector("[data-role='copy-icon-copied']")

      if (
        !(copyElement instanceof HTMLElement) ||
        !(commandText instanceof HTMLElement) ||
        !(statusElement instanceof HTMLElement)
      ) {
        return
      }

      this.#copyElement = copyElement
      this.#commandText = commandText
      this.#statusElement = statusElement
      // SVGs are SVGElement, not HTMLElement — instanceof HTMLElement fails
      if (copyIdleIcon instanceof Element) this.#copyIdleIcon = copyIdleIcon
      if (copySuccessIcon instanceof Element) this.#copySuccessIcon = copySuccessIcon

      this.#copyElement.addEventListener("click", this.#onCopyClick)
      this.#copyElement.addEventListener("keydown", this.#onCopyKeyDown)

      this.#setActivePM(DEFAULT_PACKAGE_MANAGER)
    }

    disconnectedCallback() {
      if (this.#pmChip) {
        this.#pmChip.removeEventListener("click", this.#onPMChipClick)
      }
      this.#pmOptions.forEach((el) => {
        el.removeEventListener("click", this.#onPMSelect)
      })
      this.#pmOptions.clear()

      document.removeEventListener("mousedown", this.#onOutsideClick)
      document.removeEventListener("keydown", this.#onEscape)

      if (this.#copyElement) {
        this.#copyElement.removeEventListener("click", this.#onCopyClick)
        this.#copyElement.removeEventListener("keydown", this.#onCopyKeyDown)
      }

      if (this.#copyResetTimeout !== undefined) {
        clearTimeout(this.#copyResetTimeout)
      }

      this.#copyElement = null
      this.#commandText = null
      this.#statusElement = null
      this.#copyIdleIcon = null
      this.#copySuccessIcon = null
      this.#pmDropdown = null
      this.#pmChip = null
      this.#pmChevron = null
      this.#pmPopover = null
      this.#pmIconContainer = null
      this.#pmLabel = null
      this.#copyResetTimeout = undefined
    }

    #setActivePM = (pm: PackageManager) => {
      this.#activePM = pm

      if (this.#commandText) {
        this.#commandText.textContent = getInstallCommand(pm)
      }

      if (this.#pmIconContainer) {
        const iconElements = this.#pmIconContainer.querySelectorAll("[data-pm-icon]")
        iconElements.forEach((iconEl) => {
          if (iconEl instanceof Element) {
            const isActive = iconEl.getAttribute("data-pm-icon") === pm
            iconEl.classList.toggle("hidden", !isActive)
          }
        })
      }

      if (this.#pmLabel) {
        this.#pmLabel.textContent = pm
      }

      if (this.#pmChip) {
        this.#pmChip.setAttribute("aria-label", `Package manager: ${pm}`)
      }

      this.#pmOptions.forEach((optionEl, optionPm) => {
        const selected = optionPm === pm
        optionEl.setAttribute("aria-selected", selected ? "true" : "false")
        optionEl.classList.toggle("text-white", selected)
        optionEl.classList.toggle("text-zinc-400", !selected)

        const check = optionEl.querySelector("[data-role='pm-check']")
        if (check instanceof Element) {
          check.classList.toggle("hidden", !selected)
        }
      })
    }

    #setCopyFeedback = (state: "idle" | "copied" | "error") => {
      if (!this.#statusElement || !this.#copyIdleIcon || !this.#copySuccessIcon) return
      const copied = state === "copied"
      this.#copyIdleIcon.classList.toggle("hidden", copied)
      this.#copySuccessIcon.classList.toggle("hidden", !copied)
      this.#statusElement.textContent =
        state === "copied"
          ? "Copied"
          : state === "error"
            ? "Could not copy"
            : ""
    }

    #setTemporaryCopyFeedback = (state: "copied" | "error") => {
      this.#setCopyFeedback(state)
      if (this.#copyResetTimeout !== undefined) clearTimeout(this.#copyResetTimeout)
      this.#copyResetTimeout = setTimeout(() => {
        this.#setCopyFeedback("idle")
        this.#copyResetTimeout = undefined
      }, COPY_RESET_TIMEOUT_MS)
    }

    #onPMChipClick = (event: MouseEvent) => {
      event.stopPropagation()
      this.#pmOpen = !this.#pmOpen
      if (this.#pmChip) this.#pmChip.setAttribute("aria-expanded", String(this.#pmOpen))
      if (this.#pmPopover) this.#pmPopover.hidden = !this.#pmOpen
      if (this.#pmChevron) this.#pmChevron.classList.toggle("rotate-180", this.#pmOpen)
    }

    #onPMSelect = (event: MouseEvent) => {
      event.stopPropagation()
      const target = event.currentTarget
      if (!(target instanceof HTMLButtonElement)) return
      const pm = target.dataset.pm
      if (pm === undefined || !isPackageManager(pm)) return
      this.#setActivePM(pm)
      this.#closePopover()
    }

    #onCopyKeyDown = (event: KeyboardEvent) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault()
        this.#onCopyClick()
      }
    }

    #onCopyClick = async () => {
      const clipboard = typeof navigator === "undefined" ? undefined : navigator.clipboard
      if (clipboard === undefined) {
        this.#setTemporaryCopyFeedback("error")
        return
      }
      const text = getInstallCommand(this.#activePM)
      try {
        await clipboard.writeText(text)
        this.#setTemporaryCopyFeedback("copied")
      } catch {
        this.#setTemporaryCopyFeedback("error")
      }
    }
  }

  if (!customElements.get("effect-hero-command")) {
    customElements.define("effect-hero-command", EffectHeroCommandElement)
  }
</script>
