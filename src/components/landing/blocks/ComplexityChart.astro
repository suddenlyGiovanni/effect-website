<effect-complexity-chart class="block w-full" data-in-view="false">
  <div class="relative h-36 w-full overflow-hidden md:h-44">
    <svg
      role="img"
      aria-labelledby="complexity-chart-title complexity-chart-description"
      viewBox="0 0 400 140"
      class="h-full w-full"
      preserveAspectRatio="none"
    >
      <title id="complexity-chart-title">Complexity at Scale</title>
      <desc id="complexity-chart-description">
        A chart comparing complexity growth with and without Effect.
      </desc>

      <defs>
        <linearGradient id="complexity-red-area-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="rgb(239 68 68)" stop-opacity="0.12"></stop>
          <stop offset="100%" stop-color="rgb(239 68 68)" stop-opacity="0"></stop>
        </linearGradient>
        <linearGradient id="complexity-green-area-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="rgb(16 185 129)" stop-opacity="0.08"></stop>
          <stop offset="100%" stop-color="rgb(16 185 129)" stop-opacity="0"></stop>
        </linearGradient>
      </defs>

      {
        [0, 35, 70, 105, 140].map((y) => (
          <line
            class="chart-grid-line"
            x1="0"
            y1={y}
            x2="400"
            y2={y}
            stroke="rgb(39 39 42 / 0.5)"
            stroke-width="0.8"
          />
        ))
      }

      {
        [100, 200, 300].map((x) => (
          <line
            class="chart-grid-line"
            x1={x}
            y1="0"
            x2={x}
            y2="140"
            stroke="rgb(39 39 42 / 0.35)"
            stroke-width="0.8"
          />
        ))
      }

      <path
        class="chart-area chart-area-red"
        d="M0,118 C150,115 250,100 400,8 L400,140 L0,140 Z"
        fill="url(#complexity-red-area-gradient)"></path>
      <path
        class="chart-area chart-area-green"
        d="M0,105 C50,105 90,105 125,105 C200,100 300,92 400,85 L400,140 L0,140 Z"
        fill="url(#complexity-green-area-gradient)"></path>

      <path
        class="chart-line chart-line-red"
        d="M0,118 C150,115 250,100 400,8"
        fill="none"
        stroke="rgb(239 68 68)"
        stroke-width="1.2"
        stroke-linecap="round"></path>
      <path
        class="chart-line chart-line-green"
        d="M0,105 C50,105 90,105 125,105 C200,100 300,92 400,85"
        fill="none"
        stroke="rgb(16 185 129)"
        stroke-width="1.2"
        stroke-linecap="round"></path>
    </svg>
  </div>

  <div class="mt-3 flex justify-between">
    <span class="font-mono text-[10px] uppercase tracking-wide text-zinc-400/75">Start</span>
    <span class="font-mono text-[10px] uppercase tracking-wide text-zinc-400/75">Scale</span>
  </div>

  <div class="mt-5 flex items-center justify-center gap-6">
    <span class="font-mono text-xs uppercase tracking-wider text-zinc-400"
      >Complexity at scale:</span
    >
    <div class="flex items-center gap-1.5">
      <div class="h-1.5 w-1.5 rounded-full bg-red-500"></div>
      <span class="font-mono text-xs uppercase text-zinc-400">Without Effect</span>
    </div>
    <div class="flex items-center gap-1.5">
      <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
      <span class="font-mono text-xs uppercase text-zinc-400">With Effect</span>
    </div>
  </div>
</effect-complexity-chart>

<script>
  class EffectComplexityChartElement extends HTMLElement {
    #observer: IntersectionObserver | undefined

    connectedCallback() {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches

      if (prefersReducedMotion) {
        this.dataset.inView = "true"
        return
      }

      this.dataset.inView = "false"

      this.#observer = new IntersectionObserver(
        (entries) => {
          const [entry] = entries

          if (!entry?.isIntersecting) {
            return
          }

          this.dataset.inView = "true"
          this.#observer?.disconnect()
          this.#observer = undefined
        },
        { threshold: 0.35 },
      )

      this.#observer.observe(this)
    }

    disconnectedCallback() {
      this.#observer?.disconnect()
      this.#observer = undefined
    }
  }

  if (!customElements.get("effect-complexity-chart")) {
    customElements.define("effect-complexity-chart", EffectComplexityChartElement)
  }
</script>

<style>
  .chart-grid-line {
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
  }

  .chart-area {
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .chart-line {
    transition: stroke-dashoffset 1.2s ease;
  }

  .chart-line-red {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
  }

  .chart-line-green {
    stroke-dasharray: 450;
    stroke-dashoffset: 450;
    transition-delay: 0.12s;
  }

  effect-complexity-chart[data-in-view="true"] .chart-grid-line {
    opacity: 1;
    transform: translateY(0);
  }

  effect-complexity-chart[data-in-view="true"] .chart-area {
    opacity: 1;
  }

  effect-complexity-chart[data-in-view="true"] .chart-line-red,
  effect-complexity-chart[data-in-view="true"] .chart-line-green {
    stroke-dashoffset: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .chart-grid-line,
    .chart-area,
    .chart-line {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .chart-line-red,
    .chart-line-green {
      stroke-dashoffset: 0;
    }
  }
</style>
