---
import { Image } from "astro:assets"
import { getCollection, getEntries, render } from "astro:content"
import { ArrowRightIcon, ArrowUpRightIcon, ChevronLeftIcon, ChevronRightIcon } from "@lucide/astro"
import LinkedInLogo from "@/assets/logos/linkedin/LinkedIn.svg"
import TwitterLogo from "@/assets/logos/twitter/TwitterWhite.svg"
import CopyLinkButton from "@/components/blog/CopyLinkButton"
import TableOfContents from "@/components/blog/TableOfContents"
import PageLayout from "@/layouts/PageLayout.astro"

export async function getStaticPaths() {
  const posts = await getCollection("blog")
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)

const [tags, authors, allPosts] = await Promise.all([
  getEntries(post.data.tags),
  getEntries(post.data.authors),
  getCollection("blog"),
])

const avatars = import.meta.glob<{ default: ImageMetadata }>("../../assets/authors/*.png", {
  eager: true,
})

const sortedPosts = [...allPosts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
const currentIndex = sortedPosts.findIndex((p) => p.id === post.id)
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null
const nextPost =
  currentIndex >= 0 && currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null

const sortedTags = [...tags].sort((a, b) => a.data.name.localeCompare(b.data.name))

const postUrl = new URL(`/blog/${post.id}/`, Astro.site).href
const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl)}`
const linkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
}

function authorAvatar(id: string): ImageMetadata | undefined {
  return avatars[`../../assets/authors/${id}.png`]?.default
}

const proseClass =
  "prose prose-zinc dark:prose-invert max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-h2:mt-14 prose-h2:mb-5 prose-h2:text-2xl prose-h3:mt-10 prose-h3:mb-4 prose-h3:text-xl prose-p:text-lg prose-p:leading-relaxed prose-li:text-lg prose-pre:rounded-xl"

const shareShellClass =
  "inline-flex h-10 w-10 items-center justify-center rounded-md border border-zinc-700 text-zinc-300 transition-colors hover:border-white hover:text-white"
---

<PageLayout title={`${post.data.title} | Effect Blog`} description={post.data.excerpt} activeSlug="blog">
  <section class="relative">
    <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 h-[520px] overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="hero-fade absolute inset-0"></div>
    </div>

    <div class="relative z-10 mx-auto w-full max-w-295 px-4">
      <nav
        aria-label="Breadcrumb"
        class="flex flex-wrap items-center gap-x-3 gap-y-2 pt-16 pb-1 font-mono text-sm tracking-wider uppercase md:pt-20"
      >
        <a href="/blog" class="text-zinc-400 transition-colors hover:text-white">Blog</a>
        <span class="text-zinc-500" aria-hidden="true">//</span>
        <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
          {
            sortedTags.map((tag) => (
              <a
                href={`/blog?category=${tag.id}`}
                class="text-zinc-200 transition-colors hover:text-white"
              >
                {tag.data.name}
              </a>
            ))
          }
        </div>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-12 md:gap-x-6">
        <div class="md:col-span-8 md:row-start-1 md:pt-2 md:pb-10">
          <h1
            class="text-3xl leading-tight font-bold tracking-tight text-white md:text-4xl lg:text-[2.75rem]"
          >
            {post.data.title}
          </h1>
          <p class="mt-4 text-base leading-relaxed text-zinc-300 md:text-lg">{post.data.excerpt}</p>

          <div class="mt-8 flex flex-wrap items-center gap-4 md:hidden">
            {
              authors.map((author) => {
                const avatar = authorAvatar(author.id)
                return (
                  <a
                    href={author.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group/byline flex items-center gap-3 no-underline"
                  >
                    {avatar && (
                      <Image
                        src={avatar}
                        alt={author.data.name}
                        class="h-10 w-10 rounded-md object-cover"
                      />
                    )}
                    <span class="flex min-w-0 flex-col">
                      <span class="truncate text-base font-medium text-zinc-200 group-hover/byline:underline">
                        {author.data.name}
                      </span>
                      <span class="mt-0.5 truncate text-xs text-zinc-400">{author.data.title}</span>
                    </span>
                  </a>
                )
              })
            }
          </div>
        </div>

        <aside class="hidden md:col-start-10 md:col-span-3 md:row-start-3 md:block md:pt-16 lg:pt-20">
          <div class="mb-8 flex flex-col gap-4">
            {
              authors.map((author) => {
                const avatar = authorAvatar(author.id)
                return (
                  <a
                    href={author.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group/byline flex items-center gap-3 no-underline"
                  >
                    {avatar && (
                      <Image
                        src={avatar}
                        alt={author.data.name}
                        class="h-12 w-12 rounded-md object-cover"
                      />
                    )}
                    <span class="flex min-w-0 flex-col">
                      <span class="truncate text-base font-medium text-zinc-200 group-hover/byline:underline">
                        {author.data.name}
                      </span>
                      <span class="mt-0.5 truncate text-sm text-zinc-400">{author.data.title}</span>
                    </span>
                  </a>
                )
              })
            }
          </div>

          <div class="sticky top-[5.5rem]">
            <TableOfContents client:load headings={headings} className="static" />

            <div class="mt-6">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs font-medium tracking-wider text-zinc-500 uppercase">
                Share
              </span>
              <div class="flex items-center gap-2">
                <a
                  href={xUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Share on X"
                  class={shareShellClass}
                >
                  <TwitterLogo class="size-5" />
                </a>
                <a
                  href={linkedInUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Share on LinkedIn"
                  class={shareShellClass}
                >
                  <LinkedInLogo class="size-5" />
                </a>
                <CopyLinkButton client:load />
              </div>
            </div>
            <div class="mt-5 border-t border-zinc-800 pt-5"></div>
            <p class="flex flex-col gap-0.5">
              <span class="font-mono text-[10px] tracking-[0.12em] text-zinc-500 uppercase">
                Last updated
              </span>
              <time class="font-mono text-xs text-zinc-300 tabular-nums">
                {formatDate(post.data.date)}
              </time>
            </p>
            </div>
          </div>
        </aside>

        <hr class="col-span-1 h-px w-full border-zinc-800 md:col-span-12 md:row-start-2 md:my-2" />

        <article class="min-w-0 pb-20 md:col-span-8 md:row-start-3">
          <div class="mt-10 mb-10 block md:hidden">
            <TableOfContents client:load headings={headings} className="static" />
          </div>

          <div class:list={[proseClass, "blog-article mt-16 md:mt-20"]}>
            <Content />
          </div>

          <div class="mt-12 flex flex-col gap-6 border-t border-zinc-800 pt-8 md:hidden">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs font-medium tracking-wider text-zinc-500 uppercase">
                Share
              </span>
              <div class="flex items-center gap-2">
                <a
                  href={xUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Share on X"
                  class={shareShellClass}
                >
                  <TwitterLogo class="size-5" />
                </a>
                <a
                  href={linkedInUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Share on LinkedIn"
                  class={shareShellClass}
                >
                  <LinkedInLogo class="size-5" />
                </a>
                <CopyLinkButton client:load />
              </div>
            </div>
            <p class="flex flex-col gap-0.5">
              <span class="font-mono text-[10px] tracking-wider text-zinc-500 uppercase">
                Last updated
              </span>
              <time class="font-mono text-xs text-zinc-300 tabular-nums">
                {formatDate(post.data.date)}
              </time>
            </p>
          </div>

          {
            (prevPost || nextPost) && (
              <div class="mt-16 grid grid-cols-1 gap-4 border-t border-zinc-800 pt-10 sm:grid-cols-2">
                {prevPost ? (
                  <a
                    href={`/blog/${prevPost.id}`}
                    class="group flex flex-col rounded-md border border-zinc-800 px-6 py-5 transition-colors duration-200 hover:border-zinc-500"
                  >
                    <span class="flex items-center gap-1.5 font-mono text-xs tracking-wider text-zinc-500 uppercase">
                      <ChevronLeftIcon class="size-4 transition-transform duration-200 group-hover:-translate-x-0.5" />
                      Previous
                    </span>
                    <span class="mt-2 line-clamp-1 text-base font-medium text-zinc-200 transition-colors group-hover:text-white">
                      {prevPost.data.title}
                    </span>
                  </a>
                ) : (
                  <div />
                )}
                {nextPost ? (
                  <a
                    href={`/blog/${nextPost.id}`}
                    class="group flex flex-col items-end rounded-md border border-zinc-800 px-6 py-5 text-right transition-colors duration-200 hover:border-zinc-500"
                  >
                    <span class="flex items-center gap-1.5 font-mono text-xs tracking-wider text-zinc-500 uppercase">
                      Next
                      <ChevronRightIcon class="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
                    </span>
                    <span class="mt-2 line-clamp-1 text-base font-medium text-zinc-200 transition-colors group-hover:text-white">
                      {nextPost.data.title}
                    </span>
                  </a>
                ) : (
                  <div />
                )}
              </div>
            )
          }
        </article>
      </div>

      <div class="mt-16 h-px w-full bg-zinc-800"></div>
      <div
        class="grid grid-cols-1 items-center gap-6 py-12 md:grid-cols-12 md:gap-x-6 md:gap-y-8 md:py-20"
      >
        <div class="md:col-span-8">
          <p class="mb-3 font-mono text-sm font-medium tracking-wider text-zinc-400 uppercase">
            // Effect Community
          </p>
          <h2 class="text-xl font-semibold tracking-tight text-white md:text-2xl">
            Join the conversation on Discord
          </h2>
          <p class="mt-4 max-w-xl text-base leading-relaxed text-zinc-400">
            Meet engineers running Effect in production.
          </p>
        </div>
        <div class="md:col-start-9 md:col-span-4">
          <div class="relative mx-auto flex max-w-xs flex-col items-center gap-3 px-6 py-6 md:max-w-none">
            <span class="absolute top-0 left-0 h-3 w-3 border-t border-l border-zinc-700"></span>
            <span class="absolute top-0 right-0 h-3 w-3 border-t border-r border-zinc-700"></span>
            <span class="absolute bottom-0 left-0 h-3 w-3 border-b border-l border-zinc-700"></span>
            <span class="absolute right-0 bottom-0 h-3 w-3 border-r border-b border-zinc-700"></span>
            <a
              href="https://discord.gg/effect-ts"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-white px-5 py-2.5 text-sm font-medium text-zinc-950 transition-colors hover:bg-zinc-200"
            >
              Join the Discord
              <ArrowRightIcon class="size-4" />
            </a>
            <a
              href="https://discord.gg/effect-ts"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 font-mono text-xs text-zinc-400 transition-colors hover:text-zinc-200"
            >
              discord.gg/effect-ts
              <ArrowUpRightIcon class="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .hero-grid {
    background-image:
      linear-gradient(to right, rgb(24 24 27 / 0.8) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(24 24 27 / 0.8) 1px, transparent 1px);
    background-size: 196.6px 194px;
    background-position: calc(50% + 97px) 0;
  }
  .hero-fade {
    background: linear-gradient(
      to bottom,
      rgb(9 9 11) 0%,
      transparent 30%,
      transparent 50%,
      rgb(9 9 11) 100%
    );
  }
</style>
