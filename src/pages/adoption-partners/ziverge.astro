---
import {
  ArrowRight,
  ArrowUpRight,
  Bot,
  Check,
  Copy,
  GitBranch,
  GraduationCap,
  LifeBuoy,
  Rocket,
  ShieldCheck,
  Users,
  Wrench,
} from "@lucide/astro"
import { Image } from "astro:assets"
import GridBackground from "@/components/GridBackground.astro"
import ZivergeLogo from "@/assets/logos/ziverge.svg"
import PageLayout from "@/layouts/PageLayout.astro"
---

<PageLayout
  title="Ziverge — Effect Implementation Partner"
  description="Get help adopting Effect with Ziverge — implementation, team extension, and structured training."
>
  <!-- Hero — partner identity, tagline, CTAs -->
  <section class="relative w-full md:h-[36.875rem]">
    <GridBackground />
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0"
      style="background: linear-gradient(to bottom, #09090b 0%, transparent 20%, transparent 60%, #09090b 100%)"
    />
    <div class="relative mx-auto flex h-full w-full max-w-295 items-center px-4 pt-32 pb-16 md:pt-0 md:pb-0">
      <div class="grid w-full grid-cols-1 items-start gap-8 md:grid-cols-12 md:items-center">
        <div class="md:col-span-5">
          <p class="mb-3 font-mono text-sm font-medium tracking-wider text-zinc-400 uppercase">
            // Adoption Partner
          </p>
          <h1 class="leading-tighter text-3xl font-bold text-white">
            Get help adopting Effect with Ziverge
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-400">
            Effect implementation, team extension, and training, everything teams need to ship Effect in production.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a
              href="#contact"
              class="group inline-flex items-center gap-2 rounded-lg bg-white px-5 py-2.5 text-sm font-semibold text-zinc-900 no-underline transition-colors hover:bg-zinc-200 hover:no-underline"
            >
              Get in touch
              <ArrowRight class="text-base transition-transform group-hover:translate-x-0.5" size={16} aria-hidden="true" />
            </a>
            <a
              href="https://www.ziverge.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-2 rounded-lg border border-zinc-700 bg-zinc-900 px-5 py-2.5 text-sm font-medium text-white no-underline transition-colors hover:border-zinc-500 hover:bg-zinc-800 hover:no-underline"
            >
              Visit Ziverge
              <ArrowUpRight class="text-base transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" size={16} aria-hidden="true" />
            </a>
          </div>
        </div>

        <!-- Partner logo block — square -->
        <div class="relative flex aspect-square w-full items-center justify-center bg-[#121214] p-12 md:col-span-6 md:col-start-7">
          <Image
            src={ZivergeLogo}
            alt="Ziverge logo"
            class="h-auto max-h-24 w-auto max-w-[60%] object-contain"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Track-record stats + customer testimonial -->
  <section class="border-t border-zinc-800 py-24 md:pt-[108px] md:pb-24">
    <div class="mx-auto w-full max-w-295 px-4">
      <p class="mb-3 font-mono text-sm font-medium tracking-wider text-zinc-400 uppercase">
        // Track record
      </p>
      <h2 class="leading-tighter text-2xl font-semibold text-white md:text-3xl">
        Production-grade delivery, at scale
      </h2>

      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="border-x border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-4xl font-semibold text-white md:text-5xl">273+</p>
          <p class="mt-2 font-mono text-sm tracking-wider uppercase" style="color: #FFA083">Projects Delivered</p>
        </div>
        <div class="border-x border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-4xl font-semibold text-white md:text-5xl">27+</p>
          <p class="mt-2 font-mono text-sm tracking-wider uppercase" style="color: #FFA083">Clients Served</p>
        </div>
        <div class="border-x border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-4xl font-semibold text-white md:text-5xl">15+</p>
          <p class="mt-2 font-mono text-sm tracking-wider uppercase" style="color: #FFA083">Countries</p>
        </div>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-12">
        <figure class="flex flex-col border-x border-zinc-800 bg-zinc-900/40 p-6 lg:col-span-5">
          <blockquote class="flex-1 text-lg leading-relaxed text-zinc-200">
            "Ziverge brought a level of functional programming depth we couldn't hire for internally. The engagement moved fast and the output was production quality from day one."
          </blockquote>
          <figcaption class="mt-5 font-mono text-xs tracking-wider text-zinc-400 uppercase">
            — Engineering Leader, Coralogix
          </figcaption>
        </figure>
        <figure class="flex flex-col border-x border-zinc-800 bg-zinc-900/40 p-8 pb-6 lg:col-span-7">
          <blockquote class="flex-1 text-base leading-relaxed text-zinc-200">
            "In the early days of Effect I reached out to John for advice, and his insights have been essential for the initial design of Effect. As part of that collaboration I got the opportunity to participate in some of his ZIO workshops. I was very inspired by the quality and dedication that John puts into developing training material, and by the structure of his workshops. I look forward to seeing him do the same for Effect in TypeScript."
          </blockquote>
          <figcaption class="mt-5 font-mono text-xs tracking-wider text-zinc-400 uppercase">
            — Michael Arnaldi, Creator of Effect
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- What we offer — service cards -->
  <section class="border-t border-zinc-800 py-24 md:pt-40 md:pb-24">
    <div class="mx-auto w-full max-w-295 px-4">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-3 font-mono text-sm font-medium tracking-wider text-zinc-400 uppercase">
            // Services
          </p>
          <h2 class="leading-tighter text-2xl font-semibold text-white md:text-3xl">
            What Ziverge offers
          </h2>
        </div>
        <a
          href="#contact"
          class="group inline-flex shrink-0 items-center gap-2 rounded-lg bg-white px-5 py-2.5 text-sm font-semibold text-zinc-900 no-underline transition-colors hover:bg-zinc-200 hover:no-underline"
        >
          Get in touch
          <ArrowRight class="text-base transition-transform group-hover:translate-x-0.5" size={16} aria-hidden="true" />
        </a>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="flex flex-col border border-zinc-700 bg-zinc-900/40 p-6 md:p-8">
          <Wrench class="mb-4 text-zinc-300" size={24} aria-hidden="true" />
          <h3 class="leading-tighter text-lg font-semibold text-white">Implementation & Consulting</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Hands-on Effect adoption for your production codebase. Ziverge assesses your stack, designs the migration path, and implements with the depth that only comes from building Effect systems for over a decade.
          </p>
        </div>
        <div class="flex flex-col border border-zinc-700 bg-zinc-900/40 p-6 md:p-8">
          <Users class="mb-4 text-zinc-300" size={24} aria-hidden="true" />
          <h3 class="leading-tighter text-lg font-semibold text-white">Team Extension</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Embed Ziverge engineers alongside your team. They work in your repos, participate in your development process, and collaborate on code reviews, accelerating Effect adoption while also helping your engineers build fluency through hands-on experience.
          </p>
        </div>
        <div class="flex flex-col border border-zinc-700 bg-zinc-900/40 p-6 md:p-8">
          <GraduationCap class="mb-4 text-zinc-300" size={24} aria-hidden="true" />
          <h3 class="leading-tighter text-lg font-semibold text-white">Training</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Structured Effect training from foundational concepts to advanced patterns: fibers, typed errors, dependency injection, and agent-native workflows.
          </p>
        </div>
        <div class="flex flex-col border border-zinc-700 bg-zinc-900/40 p-6 md:p-8">
          <LifeBuoy class="mb-4 text-zinc-300" size={24} aria-hidden="true" />
          <h3 class="leading-tighter text-lg font-semibold text-white">Open-Source & Commercial Support</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Ongoing support for teams running Effect in production, from open-source maintenance to commercial support contracts.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Training & certification feature block -->
  <section id="training" class="border-t border-zinc-800 py-24 md:pt-40 md:pb-24">
    <div class="mx-auto w-full max-w-295 px-4">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-3 font-mono text-sm font-medium tracking-wider text-zinc-400 uppercase">
            // Effect Training
          </p>
          <h2 class="leading-tighter text-2xl font-semibold text-white md:text-3xl">
            From fundamentals to production
          </h2>
        </div>
      </div>

      <div class="mt-12">
        <div class="relative">
          <ul class="grid grid-cols-1 sm:grid-cols-2">
            <li class="py-6 first:pt-0 sm:p-8 border-b border-zinc-800 sm:border-b-0 sm:pl-0 sm:pt-0">
              <GitBranch class="mb-3 text-zinc-300" size={24} aria-hidden="true" />
              <h3 class="text-lg font-semibold text-white">Concurrent systems</h3>
              <p class="mt-1.5 text-base leading-relaxed text-zinc-400">
                Fibers, scheduling, structured concurrency
              </p>
            </li>
            <li class="py-6 first:pt-0 sm:p-8 border-b border-zinc-800 sm:border-b-0 sm:pr-0 sm:pt-0">
              <ShieldCheck class="mb-3 text-zinc-300" size={24} aria-hidden="true" />
              <h3 class="text-lg font-semibold text-white">Type-safe failure modes</h3>
              <p class="mt-1.5 text-base leading-relaxed text-zinc-400">
                Typed errors, recovery, observability
              </p>
            </li>
            <li class="py-6 first:pt-0 sm:p-8 sm:pl-0 sm:pb-0">
              <Rocket class="mb-3 text-zinc-300" size={24} aria-hidden="true" />
              <h3 class="text-lg font-semibold text-white">Production reliability</h3>
              <p class="mt-1.5 text-base leading-relaxed text-zinc-400">
                Resource safety, dependency injection, lifecycle management
              </p>
            </li>
            <li class="py-6 first:pt-0 sm:p-8 sm:pr-0 sm:pb-0">
              <Bot class="mb-3 text-zinc-300" size={24} aria-hidden="true" />
              <h3 class="text-lg font-semibold text-white">Agent-native patterns</h3>
              <p class="mt-1.5 text-base leading-relaxed text-zinc-400">
                AI workflows, deterministic execution
              </p>
            </li>
          </ul>
          <!-- Dashed dividers (cross) -->
          <div aria-hidden="true" class="pointer-events-none absolute top-0 left-1/2 hidden h-[calc(50%-1.5rem)] w-px -translate-x-1/2 text-zinc-700 sm:block" style="background-image: repeating-linear-gradient(to bottom, currentColor 0 3px, transparent 3px 6px)" />
          <div aria-hidden="true" class="pointer-events-none absolute bottom-0 left-1/2 hidden h-[calc(50%-1.5rem)] w-px -translate-x-1/2 text-zinc-700 sm:block" style="background-image: repeating-linear-gradient(to bottom, currentColor 0 3px, transparent 3px 6px)" />
          <div aria-hidden="true" class="pointer-events-none absolute top-1/2 left-0 hidden h-px w-[calc(50%-1.5rem)] -translate-y-1/2 text-zinc-700 sm:block" style="background-image: repeating-linear-gradient(to right, currentColor 0 3px, transparent 3px 6px)" />
          <div aria-hidden="true" class="pointer-events-none absolute top-1/2 right-0 hidden h-px w-[calc(50%-1.5rem)] -translate-y-1/2 text-zinc-700 sm:block" style="background-image: repeating-linear-gradient(to right, currentColor 0 3px, transparent 3px 6px)" />
        </div>
      </div>
    </div>
  </section>

  <!-- What this means for your team — differentiators -->
  <section class="border-t border-zinc-800 py-24">
    <div class="mx-auto grid w-full max-w-295 grid-cols-1 gap-12 px-4 md:grid-cols-12">
      <div class="md:col-span-5 md:flex md:items-center">
        <div>
          <p class="mb-3 font-mono text-sm font-medium tracking-wider text-zinc-400 uppercase">
            // Why Ziverge
          </p>
          <h2 class="leading-tighter text-2xl font-semibold text-white md:max-w-md md:text-3xl">
            What this means for your team
          </h2>
        </div>
      </div>

      <div class="flex flex-col divide-y divide-zinc-800 md:col-span-7 md:col-start-6 lg:col-span-6 lg:col-start-7">
        <div class="py-8 first:pt-0 last:pb-0">
          <div class="flex items-baseline gap-5">
            <p class="font-mono text-xl font-medium text-zinc-700">01</p>
            <h3 class="leading-tighter text-xl font-semibold text-white">Deep Effect expertise</h3>
          </div>
          <p class="mt-3 text-base leading-relaxed text-zinc-400 md:max-w-xl md:pl-12">
            Over a decade of building effect systems, from ZIO to Effect.
          </p>
          <a
            href="https://www.youtube.com/watch?v=Ei6VTwhI8QQ"
            target="_blank"
            rel="noopener noreferrer"
            class="group mt-4 inline-flex w-fit items-center gap-2 text-sm font-medium text-white no-underline hover:no-underline md:ml-12"
          >
            <!-- YouTube icon (inline SVG — rectangle + play triangle) -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="shrink-0 text-white" aria-hidden="true">
              <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
            </svg>
            Why Effect is more important than ZIO — John A. De Goes
            <ArrowUpRight class="text-base transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" size={16} aria-hidden="true" />
          </a>
        </div>
        <div class="py-8 first:pt-0 last:pb-0">
          <div class="flex items-baseline gap-5">
            <p class="font-mono text-xl font-medium text-zinc-700">02</p>
            <h3 class="leading-tighter text-xl font-semibold text-white">Enterprise-grade delivery</h3>
          </div>
          <p class="mt-3 text-base leading-relaxed text-zinc-400 md:max-w-xl md:pl-12">
            Effect expertise paired with the engineering discipline to ship: architecture, reviews, and production readiness.
          </p>
        </div>
        <div class="py-8 first:pt-0 last:pb-0">
          <div class="flex items-baseline gap-5">
            <p class="font-mono text-xl font-medium text-zinc-700">03</p>
            <h3 class="leading-tighter text-xl font-semibold text-white">Proven training pedigree</h3>
          </div>
          <p class="mt-3 text-base leading-relaxed text-zinc-400 md:max-w-xl md:pl-12">
            Structured workshops from fundamentals to advanced patterns, endorsed by Effectful, the team behind Effect.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact — direct email to the partner -->
  <section id="contact" class="relative overflow-hidden border-t border-zinc-800 py-24 md:py-32">
    <GridBackground />
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0"
      style="background: linear-gradient(to bottom, #09090b 0%, transparent 25%, transparent 75%, #09090b 100%)"
    />

    <div class="relative mx-auto w-full max-w-295 px-4">
      <div class="flex flex-col items-center text-center">
        <p class="mb-3 font-mono text-sm font-medium tracking-wider text-zinc-400 uppercase">
          // Get in touch
        </p>
        <h2 class="leading-tighter max-w-2xl text-3xl font-bold text-white md:text-4xl">
          Ready to build?
        </h2>
        <p class="mt-4 max-w-[40rem] text-lg leading-normal text-zinc-400">
          Share where you are with Effect and what you're trying to
          build. Your inquiry goes directly to{" "}
          Ziverge, who will scope the
          right engagement, and get back to you quickly.
        </p>
        <button
          type="button"
          id="copy-email-btn"
          data-email="contact@ziverge.com"
          aria-label="Copy email address contact@ziverge.com"
          class="group mt-[37px] flex w-full max-w-[395px] cursor-pointer items-center justify-between gap-3 border border-zinc-700 bg-zinc-900/60 px-4 py-4 font-mono text-base backdrop-blur-sm transition-colors hover:border-zinc-500 hover:bg-zinc-900"
          style="color: #FFA083"
        >
          contact@ziverge.com
          <Copy data-role="copy-icon-idle" class="shrink-0 text-zinc-400 transition-colors group-hover:text-zinc-200" size={20} aria-hidden="true" />
          <Check data-role="copy-icon-copied" class="hidden shrink-0 text-zinc-200" size={20} aria-hidden="true" />
        </button>
      </div>
    </div>
  </section>
</PageLayout>

<script is:inline>
  // Email copy-to-clipboard
  (function () {
    var btn = document.getElementById("copy-email-btn")
    if (!btn) return
    var email = btn.getAttribute("data-email")
    var idleIcon = btn.querySelector('[data-role="copy-icon-idle"]')
    var copiedIcon = btn.querySelector('[data-role="copy-icon-copied"]')
    btn.addEventListener("click", function () {
      if (!email) return
      navigator.clipboard.writeText(email).then(function () {
        if (idleIcon) idleIcon.classList.add("hidden")
        if (copiedIcon) copiedIcon.classList.remove("hidden")
        setTimeout(function () {
          if (idleIcon) idleIcon.classList.remove("hidden")
          if (copiedIcon) copiedIcon.classList.add("hidden")
        }, 1500)
      })
    })
  })()
</script>
