---
import type { CollectionEntry } from "astro:content"
import { getCollection, render } from "astro:content"

import Footer from "@/components/Footer.astro"
import Navigation from "@/components/navigation/Navigation.astro"
import BaseLayout from "@/layouts/BaseLayout.astro"
import { PAGE_TITLE_ID } from "@/lib/constants/skip-link"

export async function getStaticPaths() {
  const entries = await getCollection("docs")
  return entries.map((entry) => {
    const slug = entry.id.replace(/\/index$/, "")
    return {
      params: { slug },
      props: { entry, entries },
    }
  })
}

const { entry, entries } = Astro.props
const { Content, headings } = await render(entry)

const currentId = entry.id
const currentVersion = currentId.split("/")[0]
const versions = ["v4", "v3"] as const

const sidebarConfigs = import.meta.glob<{ default: Record<string, number> }>(
  "../../content/docs/**/_sidebar.json",
  { eager: true },
)

const groupConfig: Record<string, number> = (() => {
  const key = Object.keys(sidebarConfigs).find((k) => k.includes(`/${currentVersion}/_sidebar.json`))
  return key ? (sidebarConfigs[key]?.default ?? {}) : {}
})()

function sidebarLabel(e: CollectionEntry<"docs">): string {
  return e.data.sidebar?.label ?? e.data.title
}

function sidebarOrder(e: CollectionEntry<"docs">): number {
  return e.data.sidebar?.order ?? Infinity
}

function sortEntries(list: CollectionEntry<"docs">[]): CollectionEntry<"docs">[] {
  return [...list].sort((a, b) => {
    const diff = sidebarOrder(a) - sidebarOrder(b)
    return diff !== 0 ? diff : sidebarLabel(a).localeCompare(sidebarLabel(b))
  })
}

interface SidebarGroup {
  dir: string
  label: string
  entries: CollectionEntry<"docs">[]
  isOpen: boolean
}

const roots: CollectionEntry<"docs">[] = []
const groupMap = new Map<string, CollectionEntry<"docs">[]>()

for (const e of entries.filter((e) => e.id.startsWith(`${currentVersion}/`))) {
  const withoutVersion = e.id.slice(currentVersion.length + 1)
  const parts = withoutVersion.split("/")
  if (parts.length === 1) {
    roots.push(e)
  } else {
    const dir = parts[0]
    if (!groupMap.has(dir)) groupMap.set(dir, [])
    groupMap.get(dir)!.push(e)
  }
}

const groups: SidebarGroup[] = []
for (const [dir, groupEntries] of groupMap) {
  groups.push({
    dir,
    label: dir
      .split("-")
      .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(" "),
    entries: sortEntries(groupEntries),
    isOpen: groupEntries.some((e) => e.id === currentId),
  })
}
function groupOrder(g: SidebarGroup): number | undefined {
  if (g.dir in groupConfig) return groupConfig[g.dir]
  const orders = g.entries.map((e) => e.data.sidebar?.order).filter((o): o is number => o !== undefined)
  return orders.length > 0 ? Math.min(...orders) : undefined
}

type SidebarItem =
  | { kind: "entry"; entry: CollectionEntry<"docs"> }
  | { kind: "group"; group: SidebarGroup }

const sidebarItems: SidebarItem[] = [
  ...roots.map((e) => ({ kind: "entry" as const, entry: e })),
  ...groups.map((g) => ({ kind: "group" as const, group: g })),
]

sidebarItems.sort((a, b) => {
  const ao = a.kind === "entry" ? a.entry.data.sidebar?.order : groupOrder(a.group)
  const bo = b.kind === "entry" ? b.entry.data.sidebar?.order : groupOrder(b.group)
  if (ao !== undefined && bo !== undefined) return ao - bo
  if (ao !== undefined) return -1
  if (bo !== undefined) return 1
  const al = a.kind === "entry" ? sidebarLabel(a.entry) : a.group.label
  const bl = b.kind === "entry" ? sidebarLabel(b.entry) : b.group.label
  return al.localeCompare(bl)
})

function entryHref(e: CollectionEntry<"docs">): string {
  return `/docs/${e.id.replace(/\/index$/, "")}`
}

function versionRootHref(version: string): string {
  return `/docs/${version}`
}

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3)
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="relative w-full">
    <Navigation activeSlug="docs" />

    <div class="relative w-full pt-16">
      <div class="mx-auto grid w-full max-w-[88rem] grid-cols-1 lg:grid-cols-[240px_1fr_240px]">

        <!-- Left sidebar -->
        <aside class="hidden border-r border-zinc-200 lg:block dark:border-zinc-800">
          <nav
            aria-label="Documentation navigation"
            class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto px-6 py-8"
          >
            <!-- Version switcher -->
            <div
              role="group"
              aria-label="Documentation version"
              class="mb-6 inline-flex items-center rounded-lg border border-zinc-200 bg-zinc-100 p-0.5 dark:border-zinc-800 dark:bg-zinc-900"
            >
              {
                versions.map((v) => (
                  <a
                    href={versionRootHref(v)}
                    aria-current={currentVersion === v ? "page" : undefined}
                    class:list={[
                      "rounded-md px-3 py-1 text-xs font-medium transition-all duration-150",
                      currentVersion === v
                        ? "bg-white text-zinc-900 shadow-sm dark:bg-zinc-700 dark:text-white"
                        : "text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200",
                    ]}
                  >
                    {v === "v4" ? "v4 (latest)" : v}
                  </a>
                ))
              }
            </div>

            <ul class="flex flex-col gap-0.5">
              {
                sidebarItems.map((item) =>
                  item.kind === "entry" ? (
                    <li>
                      <a
                        href={entryHref(item.entry)}
                        aria-current={item.entry.id === currentId ? "page" : undefined}
                        class:list={[
                          "flex items-center justify-between rounded px-2 py-2.5 -mx-2 font-mono text-sm font-medium tracking-wider uppercase transition-colors",
                          item.entry.id === currentId
                            ? "bg-zinc-100 text-zinc-900 dark:bg-zinc-800 dark:text-white"
                            : "text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white",
                        ]}
                      >
                        {sidebarLabel(item.entry)}
                      </a>
                    </li>
                  ) : (
                    <li class="mb-1 last:mb-0">
                      <details open={item.group.isOpen || undefined}>
                        <summary class="flex cursor-pointer select-none list-none items-center justify-between rounded py-2.5 font-mono text-sm font-medium tracking-wider text-zinc-700 uppercase transition-colors hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white">
                          <span>{item.group.label}</span>
                          <i
                            class="ri-arrow-down-s-line text-base transition-transform details-chevron"
                            aria-hidden="true"
                          />
                        </summary>
                        <ul class="flex flex-col gap-0.5 pb-4">
                          {item.group.entries.map((e) => {
                            const isCurrent = e.id === currentId
                            return (
                              <li>
                                <a
                                  href={entryHref(e)}
                                  aria-current={isCurrent ? "page" : undefined}
                                  class:list={[
                                    "block rounded-md py-1.5 pl-3 text-sm transition-colors",
                                    isCurrent
                                      ? "bg-zinc-100 font-semibold text-zinc-900 dark:bg-zinc-800 dark:text-white"
                                      : "text-zinc-700 hover:bg-zinc-50 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-900/60 dark:hover:text-white",
                                  ]}
                                >
                                  {sidebarLabel(e)}
                                </a>
                              </li>
                            )
                          })}
                        </ul>
                      </details>
                    </li>
                  )
                )
              }
            </ul>
          </nav>
        </aside>

        <!-- Main content -->
        <main id={PAGE_TITLE_ID} class="min-w-0 px-6 py-12 lg:px-12 lg:py-16">
          <article
            class="prose prose-zinc dark:prose-invert prose-sm md:prose-base max-w-none
                   prose-headings:font-semibold prose-headings:tracking-tight
                   prose-a:text-sky-400 prose-a:no-underline hover:prose-a:underline
                   prose-code:text-zinc-200 prose-code:bg-zinc-800 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
                   prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-700"
          >
            <h1 class="!mt-0">{entry.data.title}</h1>
            <Content />
          </article>
        </main>

        <!-- Right TOC -->
        {
          tocHeadings.length > 0 && (
            <aside class="hidden border-l border-zinc-200 lg:block dark:border-zinc-800">
              <nav
                aria-label="On this page"
                class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto px-6 py-10"
              >
                <p class="mb-4 font-mono text-sm font-medium tracking-wider text-zinc-700 uppercase dark:text-zinc-300">
                  On this page
                </p>
                <div class="mb-5 h-px bg-zinc-200 dark:bg-zinc-800" />
                <ul class="flex flex-col gap-3">
                  {tocHeadings.map((heading) => (
                    <li class={heading.depth === 3 ? "pl-3" : ""}>
                      <a
                        href={`#${heading.slug}`}
                        data-toc-link={heading.slug}
                        class="block text-sm leading-snug text-zinc-700 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }
      </div>
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  details[open] > summary .details-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]")
  if (links.length > 0) {
    const ACTIVE = ["font-semibold", "text-zinc-900", "dark:text-white"]
    const INACTIVE = ["text-zinc-700", "dark:text-zinc-400"]

    function setActive(id: string | null) {
      for (const link of links) {
        const isActive = link.dataset.tocLink === id
        link.setAttribute("aria-current", isActive ? "location" : "false")
        if (isActive) {
          link.classList.add(...ACTIVE)
          link.classList.remove(...INACTIVE)
        } else {
          link.classList.remove(...ACTIVE)
          link.classList.add(...INACTIVE)
        }
      }
    }

    const headingIds = Array.from(links).map((l) => l.dataset.tocLink!)
    const headings = headingIds.map((id) => document.getElementById(id)).filter((el): el is HTMLElement => el !== null)

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)
        if (visible.length > 0) setActive(visible[0].target.id)
      },
      { rootMargin: "-80px 0px -70% 0px", threshold: 0 },
    )

    for (const el of headings) observer.observe(el)
  }
</script>
