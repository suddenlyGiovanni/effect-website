---
import { getCollection, render } from "astro:content";
import DitheredOverlay from "@/components/DitheredOverlay.astro";
import GridRails from "@/components/GridRails.astro";
import Navigation from "@/components/navigation/Navigation.astro";
import { PodcastEpisodeRoot } from "@/features/podcast/components/PodcastEpisodeRoot";
import {
  readPodcastTranscript,
  slugifyPodcast,
} from "@/features/podcast/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { PAGE_TITLE_ID } from "@/lib/constants/skip-link";

export async function getStaticPaths() {
  const entries = await getCollection("podcasts");
  return entries.map((entry) => {
    const slug = slugifyPodcast(entry.data);
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;

const episode = entry.data;
const transcript = await readPodcastTranscript(entry);
const { Content } = await render(entry);
---

<BaseLayout>
  <DitheredOverlay />

  <div class="relative z-10">
    <Navigation />
    <GridRails />

    <main id={PAGE_TITLE_ID} class="pt-16">
      <section class="relative w-full py-8 lg:py-12 overflow-hidden">
        <div class="relative mx-auto max-w-295 px-4">
          <p
            class="mb-2 text-sm text-muted-foreground font-mono font-medium tracking-wider uppercase"
          >
            // Episode #{episode.episodeNumber}
          </p>
          <h1 class="text-4xl text-white font-bold">
            {episode.title}
          </h1>
        </div>
      </section>

      <section class="w-full py-8 border-t border-zinc-800">
        <div class="relative mx-auto max-w-295 px-4">
          <PodcastEpisodeRoot
            client:load
            podcast={entry.data}
            transcript={transcript}
          >
            <div class="prose prose-zine dark:prose-invert prose-h2:mt-0">
              <Content />
            </div>
          </PodcastEpisodeRoot>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
