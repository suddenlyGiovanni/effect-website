---
import { ArrowRightIcon } from "@lucide/astro"
import { AstroError } from "astro/errors"
import { type CollectionEntry, getCollection, render } from "astro:content"
import fs from "node:fs/promises"
import * as NodePath from "node:path"
import SrtParser from "srt-parser-2"
import Link from "@/components/Link.astro"
import { PodcastEpisodeRoot } from "@/features/podcast/components/PodcastEpisodeRoot"
import { slugifyPodcast } from "@/features/podcast/utils"
import PageLayout from "@/layouts/PageLayout.astro"

async function readPodcastTranscript(entry: CollectionEntry<"podcasts">) {
  const episodeDir = NodePath.dirname(entry.filePath ?? "")
  const path = NodePath.join(NodePath.resolve(), episodeDir, "transcript.srt")

  let content: Buffer

  try {
    content = await fs.readFile(path)
  } catch {
    throw new AstroError(
      `Failed to read transcript file from \`${path}\`.`,
      `Make sure the transcript file path provided in the video entry frontmatter is correct.

- Entry: \`${entry.filePath}\`
- Transcript: \`${path}\``,
    )
  }

  return new SrtParser().fromSrt(content.toString())
}

export async function getStaticPaths() {
  const entries = await getCollection("podcasts")
  return entries.map((entry) => {
    const slug = slugifyPodcast(entry.data)
    return {
      params: { slug },
      props: { entry },
    }
  })
}

const { entry } = Astro.props

const episode = entry.data
const episodeNumber = String(episode.episodeNumber).padStart(2, "0")
const transcript = await readPodcastTranscript(entry)
const { Content } = await render(entry)
---

<PageLayout activeSlug="podcast">
  <section class="relative w-full py-8 lg:py-12 overflow-hidden">
    <div class="relative mx-auto max-w-295 px-4">
      <div
        class="mb-2 flex flex-wrap items-center gap-2 text-sm tracking-wider text-zinc-500 font-mono font-medium uppercase"
      >
        <Link
          href="/podcast/"
          class="text-inherit hover:text-white no-underline hover:underline hover:underline-offset-4"
        >
          Cause & Effect
        </Link>
        <span>🎙️</span>
        <span aria-hidden="true">/</span>
        <span>Episode #{episodeNumber}</span>
      </div>
      <h1 class="max-w-2/3 text-3xl text-white font-semibold tracking-tight">
        {episode.title}
      </h1>
    </div>
  </section>

  <section class="w-full py-8 border-t border-zinc-800">
    <div class="relative mx-auto max-w-295 px-4">
      <PodcastEpisodeRoot client:load podcast={entry.data} transcript={transcript}>
        <div class="mt-8 prose prose-zinc dark:prose-invert prose-h2:mt-0">
          <Content />
        </div>
      </PodcastEpisodeRoot>
    </div>
  </section>

  <section class="relative w-full border-y border-zinc-800 py-12 md:py-20">
    <div aria-hidden="true" class="cta-background-gradient pointer-events-none absolute inset-0">
    </div>
    <div class="relative mx-auto max-w-295 px-4 text-center">
      <p class="mb-3 font-mono text-sm font-medium tracking-wider text-zinc-400 uppercase">
        // Cause &amp; Effect 🎙️
      </p>
      <h3 class="text-2xl md:text-3xl font-semibold tracking-tight text-white mx-4 md:mx-0">
        Real&dash;world systems built with Effect
      </h3>
      <p class="mt-2 mx-auto text-zinc-400 max-w-2xl">
        Go behind the scenes with Vercel, Masterclass, and more to learn how they ship
        production-ready systems with Effect.
      </p>
      <Link
        href="/podcast/"
        class="mt-6 inline-flex items-center gap-2 rounded-md bg-white px-6 py-3 text-base font-medium text-zinc-900 transition-colors hover:bg-zinc-200 no-underline"
      >
        <span>See all episodes</span>
        <ArrowRightIcon />
      </Link>
    </div>
  </section>
</PageLayout>

<style>
  .cta-background-gradient {
    background: radial-gradient(
      circle at 50% 40%,
      rgba(34, 197, 94, 0.2) 0%,
      rgba(34, 197, 94, 0.1) 24%,
      transparent 62%
    );
  }

  @media (min-width: 768px) {
    .cta-background-gradient {
      background: radial-gradient(circle at 50% 50%, rgba(34, 197, 94, 0.12) 0%, transparent 30%);
    }
  }
</style>
