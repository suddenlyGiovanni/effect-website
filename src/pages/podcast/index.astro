---
import { Image } from "astro:assets"
import { getCollection } from "astro:content"
import { RssIcon } from "@lucide/astro"
import ApplePodcastsLogo from "@/assets/logos/apple-podcasts/ApplePodcasts.webp"
import Link from "@/components/Link.astro"
import SocialLink from "@/components/SocialLink.astro"
import PodcastEpisodeCard from "@/features/podcast/components/PodcastEpisodeCard.astro"
import { sortPodcastsByPublishDate } from "@/features/podcast/utils"
import GridBackground from "@/components/GridBackground.astro"
import PageLayout from "@/layouts/PageLayout.astro"

const collection = await getCollection("podcasts")
const podcasts = sortPodcastsByPublishDate(collection.map(({ data }) => data))
---

<PageLayout
  title="Cause & Effect Podcast"
  description="Exploring how engineers are using Effect to build reliable, production-grade software in TypeScript"
  activeSlug="podcast"
>
  <section
    id="hero"
    class="hero-section relative w-full pt-12 md:pt-24 pb-8 md:pb-24 overflow-hidden"
  >
    <!-- Grid background -->
    <GridBackground />

    <div class="relative mx-auto max-w-295 px-4">
      <div class="flex flex-col lg:flex-row justify-between items-start gap-8 lg:gap-12">
        <div class="max-w-3xl">
          <p class="mb-2 text-sm font-medium text-zinc-400 font-mono uppercase tracking-wider">
            // Cause & Effect 🎙️
          </p>
          <h1 class="text-3xl sm:text-4xl text-white font-semibold">How companies ship with Effect</h1>
          <p class="mt-2.5 text-base sm:text-lg text-zinc-400 leading-snug">
            Stories from engineering teams at Vercel, Zendesk, MasterClass, and more.
          </p>
          <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3 lg:hidden">
            <Link
              class="flex items-center gap-3 text-white transition-colors no-underline group"
              href="https://podcasts.apple.com/us/podcast/cause-effect/id1781879869"
            >
              <Image
                class="h-5 w-auto translate-x-0.5"
                src={ApplePodcastsLogo}
                alt="Listen to the Cause & Effect Podcast on Apple Podcasts"
                loading="eager"
              />
              <span class="text-sm text-white group-hover:underline group-hover:underline-offset-2"
                >Apple Podcasts</span
              >
            </Link>
            <SocialLink
              variant="spotify"
              class="flex items-center gap-2 group [&>svg]:fill-green-500"
            >
              <span class="text-sm text-white group-hover:underline group-hover:underline-offset-2"
                >Spotify</span
              >
            </SocialLink>
            <SocialLink
              variant="youtube-podcast"
              class="flex items-center gap-2 group [&_.youtube-body]:fill-red-500 [&_.youtube-play]:fill-white"
            >
              <span class="text-sm text-white group-hover:underline group-hover:underline-offset-2"
                >YouTube</span
              >
            </SocialLink>
            <Link
              class="flex items-center gap-2 text-white transition-colors no-underline group"
              href="/podcast/rss.xml"
            >
              <RssIcon class="size-5" />
              <span class="text-sm group-hover:underline group-hover:underline-offset-2">RSS</span>
            </Link>
          </div>
        </div>

        <div class="hidden lg:block">
          <div class="relative px-6 py-4">
            <!-- Corner Brackets  -->
            <span
              aria-hidden="true"
              class="absolute top-0 left-0 h-3 w-3 border-t border-l border-zinc-700"></span>
            <span
              aria-hidden="true"
              class="absolute top-0 right-0 h-3 w-3 border-t border-r border-zinc-700"></span>
            <span
              aria-hidden="true"
              class="absolute bottom-0 left-0 h-3 w-3 border-b border-l border-zinc-700"></span>
            <span
              aria-hidden="true"
              class="absolute right-0 bottom-0 h-3 w-3 border-r border-b border-zinc-700"></span>
            <p class="mb-4 font-mono text-xs text-zinc-400 tracking-wider uppercase">
              // Available on
            </p>
            <div class="flex flex-col gap-3">
              <Link
                class="flex items-center gap-3 text-white transition-colors no-underline group"
                href="https://podcasts.apple.com/us/podcast/cause-effect/id1781879869"
              >
                <Image
                  class="h-5 w-auto translate-x-0.5"
                  src={ApplePodcastsLogo}
                  alt="Listen to the Cause & Effect Podcast on Apple Podcasts"
                  loading="eager"
                />
                <span
                  class="text-sm text-white group-hover:underline group-hover:underline-offset-2"
                  >Apple Podcasts</span
                >
              </Link>
              <SocialLink
                variant="spotify"
                class="flex items-center gap-2 group [&>svg]:fill-green-500"
              >
                <span
                  class="text-sm text-white group-hover:underline group-hover:underline-offset-2"
                  >Spotify</span
                >
              </SocialLink>
              <SocialLink
                variant="youtube-podcast"
                class="flex items-center gap-2 group [&_.youtube-body]:fill-red-500 [&_.youtube-play]:fill-white"
              >
                <span
                  class="text-sm text-white group-hover:underline group-hover:underline-offset-2"
                  >YouTube</span
                >
              </SocialLink>
              <Link
                class="flex items-center gap-3 text-white transition-colors no-underline group"
                href="/podcast/rss.xml"
              >
                <RssIcon class="size-5 translate-x-0.5" />
                <span class="text-sm group-hover:underline group-hover:underline-offset-2">RSS</span>
              </Link>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="episodes" class="relative w-full gap-16 border-t border-zinc-800 bg-zinc-950">
    <div class="mx-auto max-w-295 px-4">
      <div class="flex flex-col">
        {
          podcasts.map((podcast, index) => {
            return (
              <Fragment>
                <PodcastEpisodeCard podcast={podcast} />
                {index < podcasts.length - 1 && (
                  <hr aria-hidden="true" class="h-px w-full border-0 bg-zinc-800" />
                )}
              </Fragment>
            )
          })
        }
      </div>
    </div>
  </section>
</PageLayout>

