---
import SkipLink from "@/components/SkipLink.astro"
import HeroSection from "@/components/landing/HeroSection.astro"
import InteractiveExamplesSection from "@/components/landing/InteractiveExamplesSection.astro"
import LandingRails from "@/components/landing/LandingRails.astro"
import MentalModelSection from "@/components/landing/MentalModelSection.astro"
import ProblemSection from "@/components/landing/ProblemSection.astro"
import SectionDivider from "@/components/landing/SectionDivider.astro"
import TestimonialsSection from "@/components/landing/TestimonialsSection.astro"
import Navigation from "@/components/navigation/Navigation.astro"
import BaseLayout from "@/layouts/BaseLayout.astro"
---

<BaseLayout 
  description="An open-source ecosystem for software that is scalable, reliable, and maintainable from the start. One package, everything you need."
>
  <!-- Dithered Background Overlay -->
  <div
    aria-hidden="true"
    class="pointer-events-none fixed inset-0 z-0 opacity-[0.03]"
    style='background-image: url("data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%274%27 height=%274%27%3E%3Crect x=%270%27 y=%270%27 width=%271%27 height=%271%27 fill=%27white%27/%3E%3Crect x=%272%27 y=%272%27 width=%271%27 height=%271%27 fill=%27white%27/%3E%3C/svg%3E"); background-size: 4px 4px; background-repeat: repeat;'
  ></div>

  <div class="relative z-10">
    <SkipLink />
    <Navigation />
    <LandingRails />

    <main class="pt-16">
      <HeroSection />
      <SectionDivider />
      <ProblemSection />
      <SectionDivider />
      <TestimonialsSection />
      <SectionDivider />
      <MentalModelSection />
      <SectionDivider />
      <InteractiveExamplesSection />
      <SectionDivider />
    </main>
  </div>
</BaseLayout>
