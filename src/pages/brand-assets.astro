---
import BaseLayout from "@/layouts/BaseLayout.astro"
import Navigation from "@/components/navigation/Navigation.astro"
import Footer from "@/components/Footer.astro"
import DitheredOverlay from "@/components/DitheredOverlay.astro"
import GridRails from "@/components/GridRails.astro"
import GridBackground from "@/components/GridBackground.astro"
import { PAGE_TITLE_ID } from "@/lib/constants/skip-link"
import { Download, CheckCircle, XCircle } from "@lucide/astro"
import { Image } from "astro:assets"
import EffectLogoBlack from "@/assets/logos/effect/combination-mark/svg/effect-logo-black.svg"
import EffectLogoWhite from "@/assets/logos/effect/combination-mark/svg/effect-logo-white.svg"
import LogoSymbolBlack from "@/assets/logos/effect/logo-symbol/svg/effect-logomark-black.svg"
import LogoSymbolWhite from "@/assets/logos/effect/logo-symbol/svg/effect-logomark-white.svg"

const combinationMark = {
  name: "// Combination mark",
  description: "The primary way we show the Effect brand.",
}

const logoSymbol = {
  name: "// Logo symbol",
  description: "Used when there is not enough space for the combination mark.",
}
---

<BaseLayout
  title="Effect Logo Guidelines"
  description="Download the Effect logo and brand assets for use in your projects and presentations"
>
  <div class="relative min-h-screen bg-zinc-950 text-white">
    <DitheredOverlay />
    <GridRails />

    <Navigation transparent={false} />

    <main id={PAGE_TITLE_ID} class="relative z-10 pt-16">
      <section class="hero-section relative w-full pt-16 pb-12 md:pt-20 md:pb-16">
        <GridBackground />
        <div class="hero-glow pointer-events-none absolute inset-x-0 top-0 h-[400px]"></div>

        <div class="relative mx-auto w-full max-w-295 px-4">
          <p class="mb-3 font-mono text-sm font-medium tracking-wide text-zinc-400 uppercase">
            // Logo
          </p>
          <h1 class="text-4xl font-bold leading-tighter text-white md:text-6xl">
            Effect logo guidelines
          </h1>
          <p class="mt-4 max-w-xl text-xl text-zinc-400">
            Please follow our guidelines when using the Effect logo for presentations, articles, and
            other media.
          </p>
        </div>
      </section>

      <section class="py-8">
        <div class="mx-auto w-full max-w-295 px-4">
          <div class="border-t border-zinc-800 pt-24">
            <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
              <div>
                <h2
                  class="leading-tighter mb-4 font-mono text-sm tracking-wide text-zinc-400 uppercase"
                >
                  {combinationMark.name}
                </h2>

                <div class="mb-2 flex items-center justify-start py-6">
                  <Image
                    src={EffectLogoBlack}
                    alt="Effect combination mark"
                    class="h-14 w-auto invert"
                  />
                </div>

                <p class="mb-4 text-base text-zinc-400">
                  {combinationMark.description}
                </p>

                <div class="flex items-center gap-2">
                  <Download class="size-4 text-zinc-400" />
                  <span class="text-sm text-zinc-400">Download:</span>
                  <a
                    href="/assets/effect-logo/combination-mark/effect-logo-black.png"
                    download
                    class="cursor-pointer text-sm text-white underline transition-colors hover:no-underline"
                    >PNG</a
                  >
                  <a
                    href="/assets/effect-logo/combination-mark/effect-logo-black.svg"
                    download
                    class="cursor-pointer text-sm text-white underline transition-colors hover:no-underline"
                    >SVG</a
                  >
                </div>
              </div>

              <div>
                <h2
                  class="leading-tighter mb-4 font-mono text-sm tracking-wide text-zinc-400 uppercase"
                >
                  {logoSymbol.name}
                </h2>

                <div class="mb-2 flex items-center justify-start py-6">
                  <Image
                    src={LogoSymbolBlack}
                    alt="Effect logo symbol"
                    class="h-14 w-auto invert"
                  />
                </div>

                <p class="mb-4 text-base text-zinc-400">
                  {logoSymbol.description}
                </p>

                <div class="flex items-center gap-2">
                  <Download class="size-4 text-zinc-400" />
                  <span class="text-sm text-zinc-400">Download:</span>
                  <a
                    href="/assets/effect-logo/logo-symbol/effect-logomark-black.png"
                    download
                    class="cursor-pointer text-sm text-white underline transition-colors hover:no-underline"
                    >PNG</a
                  >
                  <a
                    href="/assets/effect-logo/logo-symbol/effect-logomark-black.svg"
                    download
                    class="cursor-pointer text-sm text-white underline transition-colors hover:no-underline"
                    >SVG</a
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="pt-24">
        <div class="mx-auto w-full max-w-295 px-4">
          <div class="border-t border-zinc-800 pt-24">
            <h2
              class="leading-tighter mb-8 font-mono text-sm tracking-wide text-zinc-400 uppercase"
            >
              // Ground rules
            </h2>

            <div class="mb-24 grid grid-cols-1 gap-4 md:grid-cols-3">
              <div class="flex flex-col gap-3">
                <div
                  class="bg-zinc-950/50 flex h-52 items-center justify-center border border-zinc-700/75"
                >
                  <Image src={LogoSymbolWhite} alt="White logo on dark" class="h-24 w-auto" />
                </div>
                <span class="text-base text-zinc-400">
                  Use the white logo on a dark background.
                </span>
              </div>

              <div class="flex flex-col gap-3">
                <div class="flex h-52 items-center justify-center border border-zinc-300 bg-white">
                  <Image src={LogoSymbolBlack} alt="Black logo on light" class="h-24 w-auto" />
                </div>
                <span class="text-base text-zinc-400">
                  Use the black logo on a light background.
                </span>
              </div>

              <div class="flex flex-col gap-3">
                <div
                  class="overflow-hidden relative flex h-52 items-center justify-center border border-zinc-800"
                  style={{
                    background:
                      "linear-gradient(135deg, rgba(59, 130, 246, 0.25) 0%, rgba(99, 102, 241, 0.35) 100%)",
                  }}
                >
                  <div
                    class="absolute -top-8 -right-8 h-32 w-32 rounded-full opacity-30"
                    style={{
                      background:
                        "radial-gradient(circle, rgba(139, 92, 246, 0.6) 0%, transparent 70%)",
                    }}
                  >
                  </div>
                  <div
                    class="absolute -bottom-12 -left-12 h-40 w-40 rounded-full opacity-25"
                    style={{
                      background:
                        "radial-gradient(circle, rgba(59, 130, 246, 0.7) 0%, transparent 70%)",
                    }}
                  >
                  </div>
                  <div
                    class="absolute top-1/2 left-1/4 h-24 w-24 rounded-full opacity-20"
                    style={{
                      background:
                        "radial-gradient(circle, rgba(16, 185, 129, 0.6) 0%, transparent 70%)",
                    }}
                  >
                  </div>
                  <Image
                    src={LogoSymbolWhite}
                    alt="Logo on image"
                    class="relative z-10 h-24 w-auto"
                  />
                </div>
                <span class="text-base leading-tight text-zinc-400">
                  Use a gradient or image background, as long as the logo is clearly visible and
                  legible.
                </span>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-x-6 md:gap-y-16">
              <div class="flex flex-col gap-3">
                <div
                  class="flex h-52 items-center justify-center gap-16 border border-zinc-800 bg-zinc-950"
                >
                  <div class="relative">
                    <Image src={LogoSymbolWhite} alt="Black logo correct" class="h-20 w-auto" />
                    <CheckCircle class="absolute -right-4 -bottom-4 text-lg text-green-500" />
                  </div>
                  <div class="relative">
                    <Image
                      src={LogoSymbolWhite}
                      alt="Colored logo wrong"
                      class="h-20 w-auto"
                      style={{
                        filter:
                          "brightness(0) saturate(100%) invert(45%) sepia(95%) saturate(1000%) hue-rotate(220deg)",
                      }}
                    />
                    <XCircle class="absolute -right-4 -bottom-4 text-lg text-red-500" />
                  </div>
                </div>
                <span class="text-base text-zinc-400">
                  Do not make the logo any color other than black or white.
                </span>
              </div>

              <div class="mb-4 flex flex-col gap-3">
                <div
                  class="flex h-52 items-center justify-center gap-20 border border-zinc-800 bg-zinc-900/30 px-8"
                >
                  <div class="relative">
                    <Image src={LogoSymbolWhite} alt="Normal logo" class="h-20 w-auto" />
                    <CheckCircle class="absolute -right-4 -bottom-4 text-lg text-green-500" />
                  </div>
                  <div class="relative">
                    <Image
                      src={LogoSymbolWhite}
                      alt="Stretched logo wrong"
                      class="h-20 w-auto"
                      style={{ transform: "scaleX(1.4)" }}
                    />
                    <XCircle class="absolute -right-4 -bottom-4 text-lg text-red-500" />
                  </div>
                  <div class="relative">
                    <Image
                      src={LogoSymbolWhite}
                      alt="Squished logo wrong"
                      class="h-20 w-auto"
                      style={{ transform: "scaleY(1.4)" }}
                    />
                    <XCircle class="absolute -right-4 -bottom-4 text-lg text-red-500" />
                  </div>
                </div>
                <span class="text-base text-zinc-400">
                  Do not shrink or stretch the logo. Be sure to maintain the proportions.
                </span>
              </div>

              <div class="flex flex-col gap-3">
                <div
                  class="flex h-52 items-center justify-center gap-16 border border-zinc-800 bg-zinc-900/30"
                >
                  <div class="relative">
                    <Image src={LogoSymbolWhite} alt="Normal logo" class="h-20 w-auto" />
                    <CheckCircle class="absolute -right-4 -bottom-4 text-lg text-green-500" />
                  </div>
                  <div class="relative">
                    <Image
                      src={LogoSymbolWhite}
                      alt="Shadow logo wrong"
                      class="h-20 w-auto"
                      style={{
                        filter: "drop-shadow(4px 4px 8px rgba(0,0,0,0.4))",
                      }}
                    />
                    <XCircle class="absolute -right-4 -bottom-4 text-lg text-red-500" />
                  </div>
                </div>
                <span class="text-base text-zinc-400"> Do not place drop shadows. </span>
              </div>

              <div class="flex flex-col gap-3">
                <div
                  class="flex h-52 items-center justify-center gap-16 border border-zinc-800 bg-zinc-900/30"
                >
                  <div class="relative">
                    <Image src={LogoSymbolWhite} alt="Normal logo" class="h-20 w-auto" />
                    <CheckCircle class="absolute -right-4 -bottom-4 text-lg text-green-500" />
                  </div>
                  <div class="relative">
                    <Image
                      src={LogoSymbolWhite}
                      alt="Rotated logo wrong"
                      class="h-20 w-auto"
                      style={{ transform: "rotate(15deg)" }}
                    />
                    <XCircle class="absolute -right-4 -bottom-4 text-lg text-red-500" />
                  </div>
                </div>
                <span class="text-base text-zinc-400"> Do not rotate the logo. </span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="border-b border-zinc-800 pb-12">
        <div class="mx-auto w-full max-w-295 px-4">
          <div class="py-24">
            <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
              <div>
                <h2
                  class="leading-tighter mb-8 font-mono text-sm tracking-wide text-zinc-400 uppercase"
                >
                  // Clear space
                </h2>
                <div class="flex flex-col gap-3">
                  <div
                    class="flex h-52 items-center justify-center gap-12 border border-zinc-800 bg-zinc-900/30"
                  >
                    <div
                      class="relative p-4"
                      style={{
                        backgroundImage: `repeating-linear-gradient(
                            45deg,
                            transparent,
                            transparent 3px,
                            rgba(113, 113, 122, 0.15) 3px,
                            rgba(113, 113, 122, 0.15) 3.5px
                          )`,
                        backgroundColor: "rgba(113, 113, 122, 0.15)",
                      }}
                    >
                      <div class="bg-zinc-900/30">
                        <Image
                          src={LogoSymbolWhite}
                          alt="Logo symbol with clear space"
                          class="h-10 w-auto"
                        />
                      </div>
                    </div>
                    <div
                      class="relative p-5"
                      style={{
                        backgroundImage: `repeating-linear-gradient(
                            45deg,
                            transparent,
                            transparent 3px,
                            rgba(113, 113, 122, 0.15) 4px,
                            rgba(113, 113, 122, 0.15) 4px
                          )`,
                        backgroundColor: "rgba(113, 113, 122, 0.15)",
                      }}
                    >
                      <div class="bg-zinc-900/30">
                        <Image
                          src={EffectLogoWhite}
                          alt="Combination mark with clear space"
                          class="h-10 w-auto"
                        />
                      </div>
                    </div>
                  </div>
                  <span class="text-base text-zinc-400">
                    Maintain clear space of at least 50% of the logo height on all sides.
                  </span>
                </div>
              </div>

              <div>
                <h2
                  class="leading-tighter mb-8 font-mono text-sm tracking-wide text-zinc-400 uppercase"
                >
                  // Minimum size
                </h2>
                <div class="flex flex-col gap-3">
                  <div
                    class="flex h-52 items-center justify-center gap-16 border border-zinc-800 bg-zinc-900/30"
                  >
                    <div class="flex flex-col items-center gap-2 py-4">
                      <Image
                        src={LogoSymbolWhite}
                        alt="Logo symbol minimum size"
                        class="h-6 w-auto"
                      />
                      <span class="mb-[-1] font-mono text-xs text-zinc-400"> 24px height </span>
                    </div>
                    <div class="flex flex-col items-center gap-2">
                      <Image
                        src={EffectLogoWhite}
                        alt="Combination mark minimum size"
                        class="h-6 w-auto"
                      />
                      <span class="mb-[-1] font-mono text-xs text-zinc-400"> 24px height </span>
                    </div>
                  </div>
                  <span class="text-base text-zinc-400">
                    To ensure legibility, never scale the logo below the minimum size above.
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer class="mt-12 md:mt-24" />
  </div>
</BaseLayout>

<style>
  .hero-section {
    --hero-glow-gradient:
      radial-gradient(ellipse 50% 80% at 70% -20%, rgb(255 255 255 / 0.08) 0%, transparent 50%),
      radial-gradient(ellipse 30% 50% at 80% 0%, rgb(255 255 255 / 0.05) 0%, transparent 40%);
  }

  .hero-glow {
    background: var(--hero-glow-gradient);
  }
</style>
